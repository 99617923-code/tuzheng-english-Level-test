/* 途正英语 - 测评说明页样式 */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(240,244,248,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.6);
}

.nav-back-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nav-placeholder {
  width: 64rpx;
}

/* 滚动区域 */
.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

/* AI老师卡片 */
.teacher-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.teacher-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(27,63,145,0.10);
  flex-shrink: 0;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--brand-blue);
  margin-bottom: 8rpx;
}

.teacher-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* Section */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* Steps */
.steps {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.step-num-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-num {
  font-size: 26rpx;
  font-weight: 800;
}

.step-content {
  flex: 1;
  padding-top: 4rpx;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* Tips */
.tips-card {
  padding: 32rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* Permission */
.permission-card {
  padding: 32rpx;
}

.permission-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.permission-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.permission-info {
  flex: 1;
}

.permission-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.permission-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.permission-status {
  text-align: center;
}

.permission-granted {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-green);
}

.permission-denied {
  font-size: 24rpx;
  color: #e74c3c;
}

.permission-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(27,63,145,0.08) !important;
  color: var(--brand-blue);
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  padding: 16rpx 48rpx;
  line-height: 1.4;
}

/* Bottom */
.bottom-area {
  margin-top: 48rpx;
  padding-bottom: 32rpx;
}

.bottom-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 24rpx;
}
