/**
 * 途正英语AI分级测评 - 全局样式
 * 品牌色: 蓝 #1B3F91 / 绿 #83BA12
 * 设计风格: 毛玻璃 + 渐变背景
 */

/* ===== CSS Variables ===== */
page {
  --brand-blue: #1B3F91;
  --brand-blue-light: #2B5BA0;
  --brand-blue-dark: #142e6b;
  --brand-green: #83BA12;
  --brand-green-dark: #6a9a10;
  --text-primary: #1a2340;
  --text-secondary: #3a4a5a;
  --text-tertiary: #5a6a7a;
  --text-muted: #7a8a9a;
  --text-light: #8a95a5;
  --text-placeholder: #adb5bd;
  --bg-gradient: linear-gradient(160deg, #e8eef8 0%, #f0f4f8 30%, #eef6e8 70%, #f5f8f0 100%);
  --glass-bg: rgba(255, 255, 255, 0.60);
  --glass-bg-strong: rgba(255, 255, 255, 0.80);
  --glass-border: rgba(255, 255, 255, 0.4);
  --glass-shadow: 0 4px 20px rgba(27, 63, 145, 0.06);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 999rpx;

  font-family: "Nunito", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg-gradient);
  min-height: 100vh;
}

/* ===== Reset ===== */
view, text, image, button, input, textarea, navigator {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: inherit;
}

button::after {
  display: none;
}

/* ===== Utility Classes ===== */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
  min-width: 0;
  min-height: 0;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.shrink-0 {
  flex-shrink: 0;
}

.w-full {
  width: 100%;
}

.relative {
  position: relative;
}

.absolute {
  position: absolute;
}

.overflow-hidden {
  overflow: hidden;
}

/* ===== Glass Card ===== */
.glass-card {
  background: var(--glass-bg);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--glass-border);
  box-shadow: var(--glass-shadow);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.glass-card-strong {
  background: var(--glass-bg-strong);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--glass-border);
  box-shadow: 0 8px 32px rgba(27, 63, 145, 0.10);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* ===== Brand Button ===== */
.btn-primary {
  width: 100%;
  height: 112rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, var(--brand-blue) 0%, var(--brand-blue-light) 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(27, 63, 145, 0.30);
  transition: transform 0.15s ease;
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-primary.disabled {
  opacity: 0.5;
  box-shadow: none;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulseRing {
  0% {
    transform: scale(1);
    opacity: 0.5;
  }
  100% {
    transform: scale(2.2);
    opacity: 0;
  }
}

@keyframes soundWave {
  0%, 100% { height: 8rpx; }
  50% { height: 40rpx; }
}

.animate-fade-in {
  animation: fadeInUp 0.35s ease-out forwards;
}

.animate-fade-in-delay-1 {
  animation: fadeInUp 0.35s ease-out 0.1s forwards;
  opacity: 0;
}

.animate-fade-in-delay-2 {
  animation: fadeInUp 0.35s ease-out 0.15s forwards;
  opacity: 0;
}

.animate-fade-in-delay-3 {
  animation: fadeInUp 0.35s ease-out 0.2s forwards;
  opacity: 0;
}

.animate-fade-in-delay-4 {
  animation: fadeInUp 0.35s ease-out 0.3s forwards;
  opacity: 0;
}

.animate-pulse {
  animation: pulse 1.5s ease-in-out infinite;
}

.animate-spin {
  animation: spin 1s linear infinite;
}
