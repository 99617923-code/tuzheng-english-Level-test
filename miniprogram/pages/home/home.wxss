/* 途正英语 - 欢迎页样式（极简流程版） */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-gradient);
}

/* 装饰圆形 */
.deco-circle { position: absolute; border-radius: 50%; }
.deco-1 { top: -160rpx; right: -100rpx; width: 416rpx; height: 416rpx; background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%); }
.deco-2 { top: 40%; left: -80rpx; width: 256rpx; height: 256rpx; background: radial-gradient(circle, rgba(34,197,94,0.10) 0%, transparent 70%); }
.deco-3 { bottom: 10%; right: -60rpx; width: 320rpx; height: 320rpx; background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%); }

/* 主内容 */
.content {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* Logo行 */
.logo-row {
  display: flex;
  align-items: flex-end;
}

.logo-inner {
  display: flex;
  align-items: center;
  padding-left: 48rpx;
}

.logo-img {
  height: 56rpx;
}

/* 问候语 */
.greeting-area {
  margin-top: 32rpx;
}

.greeting {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-green);
}

/* Hero */
.hero {
  text-align: center;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
}

.title-line1 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
}

.title-line2 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--brand-blue);
  line-height: 1.3;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-muted);
  margin-top: 16rpx;
}

/* ============ 核心CTA区域 ============ */
.cta-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.start-btn-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 脉冲光环 */
.start-pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 100rpx;
  border: 3rpx solid rgba(59,130,246,0.25);
  animation: startPulse 2.5s ease-out infinite;
  pointer-events: none;
}

.start-pulse-ring.delay-1 {
  animation-delay: 1.25s;
}

@keyframes startPulse {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.35, 1.8);
    opacity: 0;
  }
}

.btn-start {
  position: relative;
  z-index: 2;
  width: 480rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 50%, #3B82F6 100%);
  background-size: 200% 200%;
  animation: gradientShift 3s ease infinite;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(59,130,246,0.35), 0 4rpx 12rpx rgba(59,130,246,0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 20rpx rgba(59,130,246,0.30);
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.cta-sub-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 20rpx;
  text-align: center;
}

/* ============ 未完成测评恢复 Banner ============ */
.resume-banner {
  margin-bottom: 24rpx;
}

.resume-banner-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  padding-top: 36rpx;
  border: 2rpx solid rgba(34,197,94,0.25);
  background: rgba(34,197,94,0.06) !important;
  position: relative;
}

.resume-close-btn {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-muted);
  opacity: 0.6;
  line-height: 1;
}

.resume-close-btn:active {
  opacity: 1;
}

.resume-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.resume-dot-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
  flex-shrink: 0;
  animation: dotPulse 1.5s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.resume-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.resume-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.resume-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.resume-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.resume-btn-continue {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.resume-btn-continue:active {
  opacity: 0.85;
}

.resume-btn-discard {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  background: rgba(0,0,0,0.04);
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
}

.resume-btn-discard:active {
  background: rgba(0,0,0,0.08);
}

/* ============ Video Card ============ */
.video-card {
  width: 100%;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.video-card:active {
  opacity: 0.9;
}

.video-thumb-wrap {
  position: relative;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(59,130,246,0.06), rgba(34,197,94,0.06));
  overflow: hidden;
}

.video-thumb {
  width: 100%;
  height: 100%;
}

.video-thumb-placeholder {
  position: absolute;
  bottom: 20rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 5rpx;
}

.video-wave-bar {
  width: 4rpx;
  border-radius: 4rpx;
  background: rgba(59,130,246,0.20);
}

.video-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.30);
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 16rpx 0 16rpx 28rpx;
  border-color: transparent transparent transparent #ffffff;
  margin-left: 6rpx;
}

.video-info {
  padding: 16rpx 28rpx;
  text-align: center;
}

.video-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-blue);
}

.video-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ============ History Entry ============ */
.history-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.history-entry:active {
  background: rgba(255,255,255,0.75);
}

.history-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(34,197,94,0.12);
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
}

.history-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.history-arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
  font-weight: 300;
}

/* 弹性空间 */
.flex-spacer {
  flex: 1;
  min-height: 16rpx;
}

/* 底部提示 */
.bottom-hint {
  padding-bottom: 16rpx;
  text-align: center;
}

.hint-text {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

/* ============ Video Modal ============ */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.75);
}

.video-modal-content {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #000000;
  box-shadow: 0 40rpx 120rpx rgba(0,0,0,0.30);
}

/* 横屏视频：宽屏展示，16:9比例 */
.video-horizontal {
  width: 88%;
}

.video-horizontal .video-player {
  width: 100%;
  height: 420rpx;
}

/* 竖屏视频：80%宽度，高度按 9:16 比例自适应 */
.video-vertical {
  width: 80%;
}

.video-vertical .video-player {
  width: 100%;
  height: 1066rpx;  /* 80% of 750rpx = 600rpx width, 600 * 16/9 ≈ 1066rpx */
}

.video-close-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ============ 未完成测评恢复弹窗（自定义弹窗） ============ */
.resume-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(6rpx);
}

.resume-modal-card {
  position: relative;
  width: 85%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.18);
  animation: resumeModalIn 0.3s ease;
}

@keyframes resumeModalIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.resume-modal-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.04);
}

.resume-modal-close:active {
  background: rgba(0,0,0,0.10);
}

.resume-modal-close-icon {
  font-size: 28rpx;
  color: #7a8a9a;
  font-weight: 600;
  line-height: 1;
}

.resume-modal-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.resume-modal-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
  flex-shrink: 0;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.resume-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2332;
}

.resume-modal-desc {
  display: block;
  font-size: 28rpx;
  color: #5a6577;
  line-height: 1.7;
  margin-bottom: 40rpx;
}

.resume-modal-actions {
  display: flex;
  gap: 20rpx;
}

.resume-modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.resume-modal-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.resume-modal-btn-restart {
  background: rgba(0,0,0,0.04);
  color: #5a6577;
  border: 1rpx solid rgba(0,0,0,0.06);
}

.resume-modal-btn-continue {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(34,197,94,0.30);
}

/* ============ 已确认分级状态 ============ */
.confirmed-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 40rpx 0;
}

.confirmed-badge-wrap {
  margin-bottom: 20rpx;
}

.confirmed-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #22c55e;
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.35);
}

.confirmed-badge-icon {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
}

.confirmed-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.confirmed-level-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 32rpx;
  border-radius: 100rpx;
  border: 3rpx solid;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  background: rgba(255,255,255,0.8);
  max-width: 85%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.confirmed-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

.confirmed-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  max-width: 480rpx;
}

.confirmed-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.confirmed-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.confirmed-btn-result {
  background: rgba(0,0,0,0.04);
  color: var(--text-secondary);
  border: 1rpx solid rgba(0,0,0,0.06);
}



/* ============ 模式选择弹窗（v1.3.0 AI智能跳级） ============ */
.mode-modal-card {
  position: relative;
  width: 90%;
  max-width: 650rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx 36rpx;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.18);
  animation: resumeModalIn 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
}

.mode-modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.mode-modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a2332;
  margin-bottom: 8rpx;
}

.mode-modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: #7a8a9a;
}

/* 加载中 */
.mode-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 16rpx;
}

.mode-loading .spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(59,130,246,0.15);
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.mode-loading-text {
  font-size: 26rpx;
  color: #7a8a9a;
}

/* 模式列表 */
.mode-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 模式卡片 */
.mode-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  border: 3rpx solid rgba(0,0,0,0.06);
  background: #fafbfc;
  transition: all 0.2s ease;
}

.mode-card:active {
  transform: scale(0.98);
}

.mode-card-selected {
  border-color: #3B82F6;
  background: rgba(59,130,246,0.04);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.12);
}

.mode-card-ai.mode-card-selected {
  border-color: #8B5CF6;
  background: rgba(139,92,246,0.04);
  box-shadow: 0 4rpx 16rpx rgba(139,92,246,0.12);
}

/* 单选按钮 */
.mode-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #c4cdd5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
  transition: all 0.2s ease;
}

.mode-radio-checked {
  border-color: #3B82F6;
  background: #3B82F6;
}

.mode-card-ai .mode-radio-checked {
  border-color: #8B5CF6;
  background: #8B5CF6;
}

.mode-radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ffffff;
}

/* 卡片内容 */
.mode-card-content {
  flex: 1;
  min-width: 0;
}

.mode-card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.mode-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2332;
}

.mode-card-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  background: linear-gradient(135deg, rgba(139,92,246,0.12), rgba(139,92,246,0.06));
  color: #8B5CF6;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.mode-card-desc {
  display: block;
  font-size: 24rpx;
  color: #5a6577;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

/* 提示列表 */
.mode-tips-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.mode-tip-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.mode-tip-dot {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.6;
  flex-shrink: 0;
}

.mode-tip-text {
  font-size: 22rpx;
  color: #7a8a9a;
  line-height: 1.6;
}

/* 确认按钮 */
.mode-modal-actions {
  margin-top: 28rpx;
}

.mode-confirm-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(59,130,246,0.30);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.mode-confirm-btn::after {
  border: none;
}

.mode-confirm-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.25);
}
