/* 途正英语 - 测评说明页样式（优化版：按钮置顶+折叠面板） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

.body {
  height: 100vh;
  padding: 0 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
}

/* ========== 顶部核心区域 ========== */
.hero-section {
  padding: 24rpx 0 32rpx;
}

/* AI外教简介 */
.hero-teacher {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.hero-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(27,63,145,0.10);
  flex-shrink: 0;
}

.hero-teacher-info {
  flex: 1;
}

.hero-teacher-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--brand-blue);
}

.hero-teacher-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 2rpx;
}

/* 授权状态条 */
.auth-status-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.auth-status-bar.auth-granted {
  background: rgba(131,186,18,0.08);
  border: 2rpx solid rgba(131,186,18,0.25);
}

.auth-status-bar.auth-pending {
  background: rgba(230,126,34,0.06);
  border: 2rpx solid rgba(230,126,34,0.20);
}

.auth-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.auth-granted .auth-icon-wrap {
  background: rgba(131,186,18,0.15);
}

.auth-pending .auth-icon-wrap {
  background: rgba(230,126,34,0.12);
}

.auth-icon {
  width: 28rpx;
  height: 28rpx;
}

.auth-text-wrap {
  flex: 1;
}

.auth-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.auth-hint {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 2rpx;
}

.auth-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--brand-green);
  flex-shrink: 0;
}

.auth-badge-warn {
  background: #e67e22;
}

.auth-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 开始测评按钮 */
.btn-start {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1B3F91 0%, #2B5BA0 100%);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(27,63,145,0.25);
  padding: 0 !important;
  margin: 0;
}

.btn-start::after {
  border: none;
}

.btn-start-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.btn-start-disabled {
  background: linear-gradient(135deg, #9ca3af 0%, #b0b8c4 100%);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.hero-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 16rpx;
}

/* ========== 分隔线 ========== */
.divider {
  height: 1rpx;
  background: rgba(27,63,145,0.08);
  margin: 8rpx 0 16rpx;
}

/* ========== 折叠面板 ========== */
.collapse-section {
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 2rpx solid rgba(27,63,145,0.06);
  overflow: hidden;
}

.collapse-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.collapse-title-wrap {
  flex: 1;
}

.collapse-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.collapse-subtitle {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.collapse-arrow {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.3s ease;
  transform: rotate(-90deg);
}

.collapse-arrow.arrow-expanded {
  transform: rotate(90deg);
}

.collapse-arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

.collapse-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.collapse-body.collapse-expanded {
  max-height: 2000rpx;
}

.collapse-inner {
  padding: 0 28rpx 24rpx;
}

/* ========== 测评原理 ========== */
.principle-card {
  padding: 20rpx;
  background: rgba(27,63,145,0.04);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border-left: 4rpx solid var(--brand-blue);
}

.principle-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ========== 流程步骤 ========== */
.flow-steps {
  display: flex;
  flex-direction: column;
}

.flow-step {
  display: flex;
  gap: 16rpx;
}

.flow-timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20rpx;
  flex-shrink: 0;
  padding-top: 6rpx;
}

.flow-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.8);
}

.flow-line {
  flex: 1;
  width: 0;
  border-left: 2rpx solid rgba(27,63,145,0.12);
  min-height: 16rpx;
}

.flow-content {
  flex: 1;
  padding-bottom: 16rpx;
}

.flow-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.flow-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.flow-icon {
  width: 22rpx;
  height: 22rpx;
}

.flow-title {
  font-size: 24rpx;
  font-weight: 700;
}

.flow-loop-badge {
  background: rgba(230,126,34,0.12);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.flow-loop-text {
  font-size: 18rpx;
  font-weight: 600;
  color: #e67e22;
}

.flow-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
  padding-left: 50rpx;
}

.loop-hint-card {
  margin-top: 8rpx;
  margin-left: 50rpx;
  padding: 12rpx 16rpx;
  background: rgba(230,126,34,0.06);
  border-radius: 10rpx;
  border-left: 3rpx solid #e67e22;
}

.loop-hint-text {
  font-size: 20rpx;
  color: #b35c10;
  line-height: 1.5;
}

/* ========== 注意事项 ========== */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tip-emoji {
  font-size: 28rpx;
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}
