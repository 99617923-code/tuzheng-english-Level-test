/* 途正英语 - 欢迎页样式（极简流程版） */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-gradient);
}

/* 装饰圆形 */
.deco-circle { position: absolute; border-radius: 50%; }
.deco-1 { top: -160rpx; right: -100rpx; width: 416rpx; height: 416rpx; background: radial-gradient(circle, rgba(27,63,145,0.08) 0%, transparent 70%); }
.deco-2 { top: 40%; left: -80rpx; width: 256rpx; height: 256rpx; background: radial-gradient(circle, rgba(131,186,18,0.10) 0%, transparent 70%); }
.deco-3 { bottom: 10%; right: -60rpx; width: 320rpx; height: 320rpx; background: radial-gradient(circle, rgba(27,63,145,0.06) 0%, transparent 70%); }

/* 主内容 */
.content {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* Logo行 */
.logo-row {
  display: flex;
  align-items: flex-end;
}

.logo-inner {
  display: flex;
  align-items: center;
  padding-left: 48rpx;
}

.logo-img {
  height: 56rpx;
}

/* 问候语 */
.greeting-area {
  margin-top: 32rpx;
}

.greeting {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-green);
}

/* Hero */
.hero {
  text-align: center;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
}

.title-line1 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
}

.title-line2 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--brand-blue);
  line-height: 1.3;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-muted);
  margin-top: 16rpx;
}

/* ============ 核心CTA区域 ============ */
.cta-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.start-btn-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 脉冲光环 */
.start-pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 100rpx;
  border: 3rpx solid rgba(27,63,145,0.25);
  animation: startPulse 2.5s ease-out infinite;
  pointer-events: none;
}

.start-pulse-ring.delay-1 {
  animation-delay: 1.25s;
}

@keyframes startPulse {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.35, 1.8);
    opacity: 0;
  }
}

.btn-start {
  position: relative;
  z-index: 2;
  width: 480rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #1B3F91 0%, #2B5BA0 50%, #1B3F91 100%);
  background-size: 200% 200%;
  animation: gradientShift 3s ease infinite;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(27,63,145,0.35), 0 4rpx 12rpx rgba(27,63,145,0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 20rpx rgba(27,63,145,0.30);
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.cta-sub-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 20rpx;
  text-align: center;
}

/* ============ 未完成测评恢复 Banner ============ */
.resume-banner {
  margin-bottom: 24rpx;
}

.resume-banner-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  padding-top: 36rpx;
  border: 2rpx solid rgba(131,186,18,0.25);
  background: rgba(131,186,18,0.06) !important;
  position: relative;
}

.resume-close-btn {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-muted);
  opacity: 0.6;
  line-height: 1;
}

.resume-close-btn:active {
  opacity: 1;
}

.resume-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.resume-dot-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #83BA12;
  flex-shrink: 0;
  animation: dotPulse 1.5s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.resume-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.resume-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.resume-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.resume-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.resume-btn-continue {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, #83BA12, #6a9a10);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.resume-btn-continue:active {
  opacity: 0.85;
}

.resume-btn-discard {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  background: rgba(0,0,0,0.04);
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
}

.resume-btn-discard:active {
  background: rgba(0,0,0,0.08);
}

/* ============ Video Card ============ */
.video-card {
  width: 100%;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.video-card:active {
  opacity: 0.9;
}

.video-thumb-wrap {
  position: relative;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(27,63,145,0.06), rgba(131,186,18,0.06));
  overflow: hidden;
}

.video-thumb {
  width: 100%;
  height: 100%;
}

.video-thumb-placeholder {
  position: absolute;
  bottom: 20rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 5rpx;
}

.video-wave-bar {
  width: 4rpx;
  border-radius: 4rpx;
  background: rgba(27,63,145,0.20);
}

.video-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1B3F91, #2B5BA0);
  box-shadow: 0 8rpx 24rpx rgba(27,63,145,0.30);
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 16rpx 0 16rpx 28rpx;
  border-color: transparent transparent transparent #ffffff;
  margin-left: 6rpx;
}

.video-info {
  padding: 16rpx 28rpx;
  text-align: center;
}

.video-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-blue);
}

.video-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ============ History Entry ============ */
.history-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.history-entry:active {
  background: rgba(255,255,255,0.75);
}

.history-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(131,186,18,0.12);
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
}

.history-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.history-arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
  font-weight: 300;
}

/* 弹性空间 */
.flex-spacer {
  flex: 1;
  min-height: 16rpx;
}

/* 底部提示 */
.bottom-hint {
  padding-bottom: 16rpx;
  text-align: center;
}

.hint-text {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

/* ============ Video Modal ============ */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.75);
}

.video-modal-content {
  position: relative;
  width: 88%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #000000;
  box-shadow: 0 40rpx 120rpx rgba(0,0,0,0.30);
}

.video-player {
  width: 100%;
  height: 420rpx;
}

.video-close-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}
