/* ========== 预估结果底部按钮组 ========== */
.estimate-action-area {
  padding: 0 !important;
}

.estimate-btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.estimate-btn-primary {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--brand-blue) 0%, var(--brand-blue-dark, #2563EB) 100%) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 40rpx rgba(59, 130, 246, 0.35);
