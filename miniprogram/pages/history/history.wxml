<!--
  途正英语AI分级测评 - 历史记录页
  全新UI设计：蓝色渐变头部 + 精致卡片列表
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="goBack">
        <image class="nav-back-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
      </view>
      <text class="nav-title-center">测评记录</text>
      <view class="nav-right-placeholder"></view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view
    scroll-y
    class="scroll-area"
    style="top: {{navBarHeight}}px;"
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
  >
    <!-- 加载中 -->
    <view wx:if="{{loading && list.length === 0}}" class="empty-state">
      <view class="spinner"></view>
      <text class="empty-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{!loading && list.length === 0}}" class="empty-state">
      <view class="empty-illustration">
        <view class="empty-circle">
          <image class="empty-icon" src="/assets/icons/history.svg" mode="aspectFit" />
        </view>
      </view>
      <text class="empty-title">暂无测评记录</text>
      <text class="empty-desc">完成一次测评后，记录将显示在这里</text>
      <button class="empty-btn" bindtap="goTest">
        <text>开始第一次测评</text>
      </button>
    </view>

    <!-- 有数据时 -->
    <block wx:if="{{list.length > 0}}">
      <!-- 统计头部卡片 -->
      <view class="stats-header animate-fade-in">
        <view class="stats-bg"></view>
        <view class="stats-content">
          <view class="stats-row">
            <view class="stat-block stat-block-sm">
              <text class="stat-number stat-number-sm">{{list.length}}</text>
              <text class="stat-label">总测评</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-block stat-block-sm">
              <text class="stat-number stat-number-sm">{{completedCount}}</text>
              <text class="stat-label">已完成</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-block stat-block-lg">
              <text class="stat-number stat-number-lg {{bestLevel ? '' : 'no-data'}}">{{bestLevel || '-'}}</text>
              <text class="stat-label">最高等级</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 记录列表 -->
      <view class="record-list">
        <view
          class="record-item animate-fade-in"
          wx:for="{{list}}"
          wx:key="sessionId"
          bindtap="viewDetail"
          data-session-id="{{item.sessionId}}"
          style="animation-delay: {{index * 0.04}}s;"
        >
          <!-- 已完成的记录 -->
          <block wx:if="{{item.status === 'completed'}}">
            <view class="item-left">
              <view class="level-badge-sm" style="background: {{item.levelColor}};">
                <text class="level-badge-text">{{item.levelName}}</text>
              </view>
            </view>
            <view class="item-center">
              <view class="item-main-row">
                <text class="item-score">{{item.overallScore}}分</text>
                <text wx:if="{{item.highestSubLevel}}" class="item-sublevel">{{item.highestSubLevel}}</text>
                <text wx:if="{{item.isConfirmedSession}}" class="confirmed-tag">已确认</text>
              </view>
              <view class="item-meta-row">
                <text class="item-meta">{{item.totalQuestions}}题</text>
                <text class="item-meta-dot">·</text>
                <text class="item-meta">{{item.durationText}}</text>
                <text class="item-meta-dot">·</text>
                <text class="item-meta">{{item.completedAtFormatted}}</text>
              </view>
            </view>
            <view class="item-right">
              <image class="chevron-icon" src="/assets/icons/chevron-right.svg" mode="aspectFit" />
            </view>
          </block>

          <!-- 未完成的记录 -->
          <block wx:else>
            <view class="item-left">
              <view class="level-badge-sm incomplete">
                <text class="level-badge-text">未完成</text>
              </view>
            </view>
            <view class="item-center">
              <view class="item-main-row">
                <text class="item-incomplete-label">测评中断</text>
              </view>
              <view class="item-meta-row">
                <text class="item-meta">{{item.totalQuestions || 0}}题</text>
                <text class="item-meta-dot">·</text>
                <text class="item-meta">{{item.durationText}}</text>
                <text class="item-meta-dot">·</text>
                <text class="item-meta">{{item.completedAtFormatted}}</text>
              </view>
            </view>
            <view class="item-right">
              <image class="chevron-icon" src="/assets/icons/chevron-right.svg" mode="aspectFit" />
            </view>
          </block>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loadingMore}}" class="loading-more">
        <view class="spinner-small"></view>
        <text class="loading-more-text">加载中...</text>
      </view>

      <view wx:elif="{{noMore && list.length > 5}}" class="no-more">
        <text class="no-more-text">— 没有更多记录了 —</text>
      </view>

      <!-- 底部安全区 -->
      <view style="height: calc(env(safe-area-inset-bottom) + 32rpx);"></view>
    </block>
  </scroll-view>
</view>
