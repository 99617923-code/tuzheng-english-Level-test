/* 途正英语 - 欢迎页样式（小程序原生适配版） */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-gradient);
}

/* 装饰圆形 */
.deco-circle { position: absolute; border-radius: 50%; }
.deco-1 { top: -160rpx; right: -100rpx; width: 416rpx; height: 416rpx; background: radial-gradient(circle, rgba(27,63,145,0.08) 0%, transparent 70%); }
.deco-2 { top: 40%; left: -80rpx; width: 256rpx; height: 256rpx; background: radial-gradient(circle, rgba(131,186,18,0.10) 0%, transparent 70%); }
.deco-3 { bottom: 10%; right: -60rpx; width: 320rpx; height: 320rpx; background: radial-gradient(circle, rgba(27,63,145,0.06) 0%, transparent 70%); }

/* 主内容 */
.content {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* Logo行 - 固定在顶部，与胶囊按钮同行 */
.logo-row {
  display: flex;
  align-items: flex-end;
}

.logo-inner {
  display: flex;
  align-items: center;
  padding-left: 48rpx;
}

.logo-img {
  height: 56rpx;
}

/* 问候语 */
.greeting-area {
  margin-top: 32rpx;
}

.greeting {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-green);
}

/* Hero */
.hero {
  text-align: center;
  margin-top: 48rpx;
  margin-bottom: 48rpx;
}

.title-line1 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
}

.title-line2 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--brand-blue);
  line-height: 1.3;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-muted);
  margin-top: 24rpx;
  max-width: 560rpx;
  margin-left: auto;
  margin-right: auto;
}

/* Video Card */
.video-card {
  width: 100%;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.video-card:active {
  opacity: 0.9;
}

.video-area {
  position: relative;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(27,63,145,0.06), rgba(131,186,18,0.06));
}

.play-btn-wrap {
  position: relative;
}

.play-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 128rpx;
  height: 128rpx;
  margin-top: -64rpx;
  margin-left: -64rpx;
  border-radius: 50%;
  background: rgba(27,63,145,0.10);
  animation: pulseRing 2s ease-out infinite;
}

.play-btn {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1B3F91, #2B5BA0);
  box-shadow: 0 8rpx 24rpx rgba(27,63,145,0.30);
}

.play-icon {
  width: 48rpx;
  height: 48rpx;
  margin-left: 6rpx;
}

.wave-bars {
  position: absolute;
  bottom: 20rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 5rpx;
}

.wave-bar {
  width: 4rpx;
  border-radius: 4rpx;
  background: rgba(27,63,145,0.20);
}

.video-info {
  padding: 20rpx 28rpx;
  text-align: center;
}

.video-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand-blue);
}

.video-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* History Entry */
.history-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
}

.history-entry:active {
  background: rgba(255,255,255,0.75);
}

.history-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(131,186,18,0.12);
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
}

.history-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.history-arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
  font-weight: 300;
}

/* 弹性空间 */
.flex-spacer {
  flex: 1;
  min-height: 24rpx;
}

/* CTA */
.cta-wrap {
  padding-bottom: 16rpx;
}

.cta-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 20rpx;
}

/* Video Modal */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.75);
}

.video-modal-content {
  width: 88%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 40rpx 120rpx rgba(0,0,0,0.30);
}

.video-player-wrap {
  width: 100%;
}

.video-player {
  width: 100%;
  height: 400rpx;
}

.video-placeholder {
  width: 100%;
  height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8eef8, #eef6e8);
}

.placeholder-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(27,63,145,0.10), rgba(131,186,18,0.10));
  margin-bottom: 28rpx;
}

.placeholder-icon {
  width: 48rpx;
  height: 48rpx;
  margin-left: 6rpx;
}

.placeholder-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-blue);
}

.placeholder-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.video-modal-footer {
  padding: 28rpx;
  text-align: center;
}

.close-btn {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-blue);
  background: rgba(27,63,145,0.06) !important;
  border-radius: var(--radius-full);
  padding: 14rpx 48rpx;
  line-height: 1.4;
}
