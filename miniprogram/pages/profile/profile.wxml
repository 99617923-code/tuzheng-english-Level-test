<!--
  途正英语 - 用户资料完善页
  登录后必须填写邮寄地址+上传付款截图才能进入测评
-->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="height: {{navBarHeight}}px;">
    <view class="nav-content" style="top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-title">完善资料</view>
    </view>
  </view>

  <!-- 主内容区 -->
  <scroll-view scroll-y class="main-content" style="padding-top: {{navBarHeight}}px;">
    <!-- 顶部提示 -->
    <view class="header-section">
      <image class="header-icon" src="{{logoUrl}}" mode="aspectFit" />
      <view class="header-title">欢迎加入途正英语</view>
      <view class="header-desc">请完善以下信息，以便我们为您提供更好的服务</view>
    </view>

    <!-- 表单区域 -->
    <view class="form-section">
      <!-- 邮寄地址卡片 -->
      <view class="form-card">
        <view class="card-header">
          <view class="card-icon address-icon">
            <text class="iconfont">📮</text>
          </view>
          <view class="card-title-group">
            <view class="card-title">邮寄地址</view>
            <view class="card-subtitle">用于邮寄礼品给您</view>
          </view>
          <view class="required-badge">必填</view>
        </view>

        <view class="form-fields">
          <!-- 收件人 -->
          <view class="field-row">
            <view class="field-label">收件人</view>
            <input
              class="field-input"
              placeholder="请输入收件人姓名"
              value="{{recipientName}}"
              bindinput="onRecipientNameInput"
              maxlength="20"
            />
          </view>

          <!-- 手机号 -->
          <view class="field-row">
            <view class="field-label">手机号</view>
            <input
              class="field-input"
              type="number"
              placeholder="请输入收件手机号"
              value="{{recipientPhone}}"
              bindinput="onRecipientPhoneInput"
              maxlength="11"
            />
          </view>

          <!-- 省市区 -->
          <picker mode="region" bindchange="onRegionChange">
            <view class="field-row">
              <view class="field-label">所在地区</view>
              <view class="field-picker {{region ? '' : 'placeholder'}}">
                {{region || '请选择省/市/区'}}
                <text class="picker-arrow">▸</text>
              </view>
            </view>
          </picker>

          <!-- 详细地址 -->
          <view class="field-row field-row-last">
            <view class="field-label">详细地址</view>
            <input
              class="field-input"
              placeholder="街道、楼栋、门牌号等"
              value="{{detailAddress}}"
              bindinput="onDetailAddressInput"
              maxlength="100"
            />
          </view>
        </view>
      </view>

      <!-- 付款截图卡片 -->
      <view class="form-card">
        <view class="card-header">
          <view class="card-icon payment-icon">
            <text class="iconfont">📷</text>
          </view>
          <view class="card-title-group">
            <view class="card-title">付款截图</view>
            <view class="card-subtitle">请上传您的付款凭证</view>
          </view>
          <view class="required-badge">必填</view>
        </view>

        <view class="upload-area" bindtap="handleChooseImage">
          <block wx:if="{{!paymentImagePath}}">
            <view class="upload-placeholder">
              <view class="upload-icon-circle">
                <text class="upload-plus">+</text>
              </view>
              <view class="upload-text">点击上传付款截图</view>
              <view class="upload-hint">支持 JPG、PNG 格式</view>
            </view>
          </block>
          <block wx:else>
            <view class="upload-preview-wrap">
              <image class="upload-preview" src="{{paymentImagePath}}" mode="aspectFit" />
              <view class="upload-replace-btn" catchtap="handleChooseImage">重新选择</view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button
        class="submit-btn {{canSubmit ? '' : 'disabled'}}"
        bindtap="handleSubmit"
        disabled="{{submitting}}"
      >
        <text wx:if="{{submitting}}" class="loading-dot">提交中...</text>
        <text wx:else>提交并开始测评</text>
      </button>
      <view class="submit-hint">提交后即可进入英语水平测评</view>
    </view>

    <!-- 底部留白 -->
    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>
