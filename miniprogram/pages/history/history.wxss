/* 途正英语 - 历史记录页样式 */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 导航栏样式使用全局 custom-nav */

/* 滚动区 */
.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid rgba(27,63,145,0.15);
  border-top-color: var(--brand-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.empty-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(131,186,18,0.08);
  margin-bottom: 32rpx;
}

.empty-icon {
  width: 56rpx;
  height: 56rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-light)) !important;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  padding: 20rpx 64rpx;
  box-shadow: 0 8rpx 24rpx rgba(27,63,145,0.25);
  line-height: 1.4;
}

/* 记录列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-card {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  position: relative;
}

.record-card:active {
  background: var(--glass-bg-strong);
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-level-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
}

.record-level-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.record-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.record-body {
  flex: 1;
}

.record-label {
  margin-bottom: 16rpx;
}

.record-label-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.record-stats {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-value.completed {
  color: var(--brand-green);
}

.stat-value.incomplete {
  color: var(--text-muted);
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.06);
}

.record-arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
}

.spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(27,63,145,0.15);
  border-top-color: var(--brand-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-more-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.no-more {
  text-align: center;
  padding: 32rpx;
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-placeholder);
}
