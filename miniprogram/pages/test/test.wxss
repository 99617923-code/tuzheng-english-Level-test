/* 途正英语 - 测评主页面样式（小程序原生适配版） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
  display: flex;
  flex-direction: column;
}

/* 级别信息条（从导航栏移出，放在内容区顶部） */
.level-info-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 16rpx;
}

.level-info-left {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.level-info-level {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--brand-blue);
}

.level-info-progress {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* 级别信息条右侧计时器 */
.level-info-timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(27,63,145,0.06);
  border-radius: var(--radius-full);
  padding: 8rpx 16rpx;
}

.timer-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.timer-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

/* 进度条 */
.progress-wrap {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  padding: 0 48rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  border-radius: 8rpx;
  background: rgba(27,63,145,0.08);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--brand-blue), var(--brand-green));
  transition: width 0.5s ease;
}

/* 主内容区 */
.main-area {
  flex: 1;
  padding: 32rpx 40rpx;
  padding-top: 48rpx;
  padding-bottom: 360rpx;
}

/* 题目卡片 */
.question-card {
  padding: 36rpx;
}

.ai-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.ai-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(27,63,145,0.10);
}

.ai-speaking-dot {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--brand-green);
  border: 4rpx solid #ffffff;
  animation: pulse 1s ease-in-out infinite;
}

.ai-info {
  flex: 1;
}

.ai-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--brand-blue);
}

.ai-status {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.question-text-wrap {
  margin-bottom: 28rpx;
}

.question-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.7;
}

/* 音频播放条 */
.audio-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(27,63,145,0.04);
  border-radius: var(--radius-lg);
  padding: 20rpx 28rpx;
  margin-bottom: 28rpx;
}

.audio-bar:active {
  background: rgba(27,63,145,0.08);
}

.audio-play-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-light));
  flex-shrink: 0;
}

.audio-play-icon {
  width: 28rpx;
  height: 28rpx;
}

.audio-waves {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 3rpx;
  height: 48rpx;
  justify-content: space-between;
}

.audio-wave-bar {
  flex: 1;
  min-width: 3rpx;
  max-width: 6rpx;
  border-radius: 5rpx;
  background: rgba(27,63,145,0.20);
  transition: height 0.2s ease;
}

.audio-wave-bar.playing {
  animation: soundWave 0.6s ease-in-out infinite;
}

.audio-duration {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

/* 用户回答 */
.user-answer {
  background: rgba(131,186,18,0.06);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.user-answer-header {
  margin-bottom: 12rpx;
}

.user-answer-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--brand-green);
}

.user-answer-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* AI分析反馈 */
.feedback-area {
  background: rgba(27,63,145,0.04);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
}

.feedback-header {
  margin-bottom: 16rpx;
}

.feedback-ai-tag {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--brand-blue);
  letter-spacing: 2rpx;
}

.feedback-score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.feedback-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.feedback-score {
  font-size: 36rpx;
  font-weight: 800;
}

.feedback-passed {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  margin-left: auto;
}

.feedback-passed.passed {
  color: #ffffff;
  background: var(--brand-green);
}

.feedback-passed.failed {
  color: #ffffff;
  background: #7a8a9a;
}

.feedback-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ============ 升级恭喜弹窗（Duolingo风格） ============ */
.levelup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
  animation: overlayFadeIn 0.3s ease;
}

@keyframes overlayFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 烟花容器 */
.firework-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 501;
}

/* 烟花粒子 */
.firework {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  animation: fireworkBurst 1.8s ease-out forwards;
}

.firework-1 { top: 20%; left: 15%; background: #FFD700; animation-delay: 0s; }
.firework-2 { top: 15%; left: 75%; background: #FF6B6B; animation-delay: 0.1s; }
.firework-3 { top: 30%; left: 85%; background: #4ECDC4; animation-delay: 0.2s; }
.firework-4 { top: 25%; left: 25%; background: #FF9F43; animation-delay: 0.15s; }
.firework-5 { top: 35%; left: 60%; background: #A29BFE; animation-delay: 0.25s; }
.firework-6 { top: 18%; left: 45%; background: #FD79A8; animation-delay: 0.05s; }
.firework-7 { top: 40%; left: 10%; background: #6C5CE7; animation-delay: 0.3s; }
.firework-8 { top: 22%; left: 90%; background: #00B894; animation-delay: 0.12s; }
.firework-9 { top: 45%; left: 80%; background: #FDCB6E; animation-delay: 0.18s; }
.firework-10 { top: 28%; left: 50%; background: #E17055; animation-delay: 0.08s; }
.firework-11 { top: 38%; left: 35%; background: #74B9FF; animation-delay: 0.22s; }
.firework-12 { top: 15%; left: 65%; background: #55EFC4; animation-delay: 0.28s; }

@keyframes fireworkBurst {
  0% {
    transform: scale(0) translateY(0);
    opacity: 1;
  }
  30% {
    transform: scale(3) translateY(-60rpx);
    opacity: 1;
  }
  100% {
    transform: scale(0.5) translateY(-200rpx);
    opacity: 0;
  }
}

/* 闪烁粒子 */
.sparkle {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: #FFD700;
  animation: sparkleFall 2s ease-out forwards;
}

.sparkle-1 { top: 10%; left: 20%; animation-delay: 0.3s; background: #FFD700; }
.sparkle-2 { top: 10%; left: 40%; animation-delay: 0.5s; background: #FF6B6B; }
.sparkle-3 { top: 10%; left: 60%; animation-delay: 0.4s; background: #4ECDC4; }
.sparkle-4 { top: 10%; left: 80%; animation-delay: 0.6s; background: #A29BFE; }
.sparkle-5 { top: 10%; left: 30%; animation-delay: 0.7s; background: #FD79A8; }
.sparkle-6 { top: 10%; left: 50%; animation-delay: 0.35s; background: #FF9F43; }
.sparkle-7 { top: 10%; left: 70%; animation-delay: 0.55s; background: #6C5CE7; }
.sparkle-8 { top: 10%; left: 90%; animation-delay: 0.45s; background: #00B894; }

@keyframes sparkleFall {
  0% {
    transform: translateY(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateY(600rpx) rotate(720deg) scale(0.3);
    opacity: 0;
  }
}

/* 内容卡片 */
.levelup-card {
  position: relative;
  z-index: 502;
  width: 560rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 32rpx 100rpx rgba(0, 0, 0, 0.25);
}

.animate-bounce-in {
  animation: bounceIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes bounceIn {
  0% {
    transform: scale(0.3);
    opacity: 0;
  }
  50% {
    transform: scale(1.05);
    opacity: 1;
  }
  70% {
    transform: scale(0.95);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 星星行 */
.levelup-star-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.levelup-star {
  font-size: 56rpx;
  animation: starPop 0.5s ease-out forwards;
  opacity: 0;
}

.star-left {
  font-size: 44rpx;
  animation-delay: 0.3s;
}

.star-center {
  font-size: 64rpx;
  animation-delay: 0.15s;
}

.star-right {
  font-size: 44rpx;
  animation-delay: 0.45s;
}

@keyframes starPop {
  0% {
    transform: scale(0) rotate(-30deg);
    opacity: 0;
  }
  60% {
    transform: scale(1.3) rotate(10deg);
    opacity: 1;
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.levelup-congrats {
  font-size: 40rpx;
  font-weight: 800;
  color: #FF9F43;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.levelup-message {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--brand-blue);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.levelup-divider {
  width: 80rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FFD700, #FF9F43);
  margin-bottom: 20rpx;
}

.levelup-encourage {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* 实时识别文字 */
.realtime-text {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
}

.realtime-label {
  display: block;
  font-size: 22rpx;
  color: var(--brand-green);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.realtime-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 底部操作区 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 32rpx 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  background: linear-gradient(to top, rgba(240,244,248,0.95) 60%, transparent);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 播放按钮 */
.listen-btn {
  width: 100%;
  height: 112rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, var(--brand-blue) 0%, var(--brand-blue-light) 100%) !important;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 40rpx rgba(27,63,145,0.30);
  line-height: 1;
}

.listen-btn::after {
  border: none;
}

.listen-icon {
  width: 40rpx;
  height: 40rpx;
}

.listen-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 录音按钮 */
.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.record-pulse-ring {
  position: absolute;
  top: 0;
  left: 50%;
  width: 192rpx;
  height: 192rpx;
  margin-top: -16rpx;
  margin-left: -96rpx;
  border-radius: 50%;
  background: rgba(27,63,145,0.10);
  animation: pulseRing 1.5s ease-out infinite;
  pointer-events: none;
}

.record-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-light));
  box-shadow: 0 12rpx 40rpx rgba(27,63,145,0.30);
  transition: transform 0.2s ease;
}

.record-btn.recording {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  box-shadow: 0 12rpx 40rpx rgba(231,76,60,0.30);
  transform: scale(1.1);
}

.record-mic-icon {
  width: 64rpx;
  height: 64rpx;
}

.record-hint {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 20rpx;
}

.record-timer {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-blue);
  margin-top: 8rpx;
  font-variant-numeric: tabular-nums;
}

.skip-row {
  margin-top: 24rpx;
}

.skip-btn {
  font-size: 26rpx;
  color: var(--text-muted);
  background: transparent !important;
  text-decoration: underline;
  line-height: 1;
  padding: 8rpx 16rpx;
}

.skip-btn::after {
  border: none;
}

/* 评估中 */
.evaluating-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid rgba(27,63,145,0.15);
  border-top-color: var(--brand-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.evaluating-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* ============ AI外教引导气泡 ============ */
.guide-area {
  padding: 0 32rpx;
}

.guide-bubble-wrap {
  width: 100%;
}

.guide-bubble {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(27,63,145,0.10);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.guide-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.guide-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.guide-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 32rpx;
}

/* 引导步骤列表 */
.guide-steps {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.guide-step-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  text-align: left;
}

.guide-step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 48rpx;
  text-align: center;
}

.guide-step-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 引导按钮 */
.guide-btns {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.guide-btn-skip {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(0,0,0,0.04) !important;
  color: var(--text-muted) !important;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 80rpx;
  padding: 0;
}

.guide-btn-skip::after {
  border: none;
}

.guide-btn-next {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #3B82F6, #2563EB) !important;
  color: #ffffff !important;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
  padding: 0;
}

.guide-btn-next::after {
  border: none;
}

.guide-btn-start {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a) !important;
  color: #ffffff !important;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 88rpx;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(131,186,18,0.30);
}

.guide-btn-start::after {
  border: none;
}

.guide-btn-start:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ============ 正在播放提示（listening阶段） ============ */
.listening-hint-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
}

.listening-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.listening-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--brand-blue);
  animation: listeningBounce 1.4s ease-in-out infinite;
}

.listening-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.listening-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes listeningBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1.2);
    opacity: 1;
  }
}

.listening-hint-text {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* 录音按钮 tap 模式 active 反馈 */
.record-btn:active {
  transform: scale(0.95);
}

.record-btn.recording:active {
  transform: scale(1.05);
}

/* 音频失败时显示题目文字（兜底） */
.question-text-fallback {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(43, 91, 160, 0.08);
  border-radius: var(--radius-lg, 16rpx);
  border-left: 6rpx solid var(--brand-blue, #3B82F6);
}

.question-text-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted, #7a8a9a);
  margin-bottom: 12rpx;
}

.question-text-content {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1a2a3a);
  line-height: 1.6;
  font-family: 'Nunito', sans-serif;
}
