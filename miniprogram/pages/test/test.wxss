  color: var(--text-muted);
}

/* 自我介绍录音中卡片 */
.intro-recording-card {
  padding: 40rpx 36rpx;
  margin-top: 20rpx;
  text-align: center;
}

.intro-recording-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.intro-recording-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ef4444;
  animation: pulse 1s ease-in-out infinite;
}

.intro-recording-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
}

.intro-recording-time {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
}

.intro-recording-waves {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.intro-wave-bar {
  width: 8rpx;
  min-height: 12rpx;
  max-height: 100rpx;
  background: linear-gradient(to top, var(--brand-blue), var(--brand-green));
  border-radius: 4rpx;
  transition: height 0.15s ease;
  animation: recordWave 0.6s ease-in-out infinite alternate;
}

.intro-wave-bar:nth-child(odd) {
  animation-delay: 0.1s;
}
.intro-wave-bar:nth-child(3n) {
  animation-delay: 0.2s;
}

.intro-recording-hint {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 自我介绍分析中卡片：五维度分析进度 */
.intro-analyzing-card {
  padding: 36rpx;
  margin-top: 20rpx;
}

.intro-analysis-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.intro-analysis-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.intro-analysis-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--brand-blue, #1B3F91);
  animation: introAnalysisPulse 1.5s ease-in-out infinite;
}

@keyframes introAnalysisPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.intro-analysis-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.intro-analysis-overall-pct {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--brand-blue, #1B3F91);
  font-variant-numeric: tabular-nums;
  transition: color 0.5s ease;
}

/* 总体进度条 */
.intro-analysis-total-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 12rpx;
  background: rgba(27, 63, 145, 0.08);
  overflow: hidden;
  margin-bottom: 28rpx;
}

.intro-analysis-total-fill {
  height: 100%;
  border-radius: 12rpx;
  background: linear-gradient(90deg, var(--brand-blue, #1B3F91), var(--brand-green, #83BA12));
  /* CSS transition驱动进度条动画，2s平滑过渡，替代JS定时器频繁setData */
  transition: width 2s ease-out, background 0.6s ease;
  min-width: 0;
}

/* 五维度分析进度列表 */
.intro-analysis-dims {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.intro-analysis-dim-item {
  opacity: 0.35;
  transition: opacity 0.5s ease;
}

.intro-analysis-dim-item.active {
  opacity: 1;
}

.intro-analysis-dim-item.completed {
  opacity: 0.75;
}

.intro-analysis-dim-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.intro-analysis-dim-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
  transition: background 0.5s ease;
}

.intro-analysis-dim-name {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  flex: 1;
}

.intro-analysis-dim-pct {
  font-size: 24rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  min-width: 70rpx;
  text-align: right;
  transition: color 0.5s ease;
}

.intro-analysis-dim-bar {
  width: 100%;
  height: 8rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.intro-analysis-dim-fill {
  height: 100%;
  border-radius: 8rpx;
  /* CSS transition驱动各维度进度条动画，1.8s平滑过渡 */
  transition: width 1.8s ease-out, background 0.5s ease;
  min-width: 0;
}

/* 底部状态 */
.intro-analysis-footer {
  margin-top: 24rpx;
  text-align: center;
}

.intro-analysis-status {
  font-size: 24rpx;
  color: var(--text-muted);
  animation: introStatusFade 2s ease-in-out infinite;
}

@keyframes introStatusFade {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 分析完成勾选动画 */
.intro-analysis-done {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
  animation: introDoneFadeIn 0.5s ease-out;
}

@keyframes introDoneFadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.intro-done-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981, #059669);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(16, 185, 129, 0.35);
  animation: introDoneCirclePop 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes introDoneCirclePop {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

.intro-done-check {
  width: 40rpx;
  height: 24rpx;
  position: relative;
}

.intro-done-check-stem {
  position: absolute;
  width: 6rpx;
  height: 24rpx;
  background: #fff;
  border-radius: 3rpx;
  right: 0;
  top: 0;
  transform: rotate(0deg);
  transform-origin: bottom right;
  animation: introDoneCheckStem 0.3s ease-out 0.3s both;
}

@keyframes introDoneCheckStem {
  from { height: 0; }
  to { height: 24rpx; }
}

.intro-done-check-kick {
  position: absolute;
  width: 6rpx;
  height: 14rpx;
  background: #fff;
  border-radius: 3rpx;
  left: 6rpx;
  bottom: 0;
  transform: rotate(90deg);
  transform-origin: bottom left;
  animation: introDoneCheckKick 0.25s ease-out 0.55s both;
}

@keyframes introDoneCheckKick {
  from { height: 0; }
  to { height: 14rpx; }
}

.intro-done-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #10B981;
  margin-bottom: 8rpx;
  animation: introDoneTextFade 0.4s ease-out 0.6s both;
}

.intro-done-sub {
  font-size: 24rpx;
  color: var(--text-muted);
  animation: introDoneTextFade 0.4s ease-out 0.8s both;
}

@keyframes introDoneTextFade {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 预估结果：多维度能力分析 ========== */
.estimate-result-section {
