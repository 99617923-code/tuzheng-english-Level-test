<!--
  途正英语AI分级测评 - 测评主页面（自适应引擎 v2）
  核心交互：自动播放外教语音 → 点击录音回答 → AI评分 → 自适应升级 → 下一题/出结果
  小程序原生适配：全局导航布局
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="handleQuit">
        <image class="nav-back-icon" src="/assets/icons/x.svg" mode="aspectFit" />
      </view>
      <view class="nav-center-info">
        <text class="nav-level">{{majorLevelDisplay}}</text>
        <text class="nav-progress">{{questionCountDisplay}} · {{subLevelDisplay}}</text>
      </view>
      <view class="nav-timer-wrap">
        <image class="timer-icon" src="/assets/icons/clock.svg" mode="aspectFit" />
        <text class="timer-text">{{timerDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-wrap" style="top: {{navBarHeight}}px;">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
  </view>

  <!-- 主内容区 -->
  <view class="main-area" style="padding-top: {{navBarHeight + 20}}px;">
    <!-- 题目卡片 -->
    <view class="question-card glass-card-strong animate-fade-in">
      <!-- AI头像 + 状态 -->
      <view class="ai-header">
        <view class="ai-avatar-wrap">
          <image class="ai-avatar" src="{{aiAvatarUrl}}" mode="aspectFill" />
          <view wx:if="{{aiSpeaking}}" class="ai-speaking-dot"></view>
        </view>
        <view class="ai-info">
          <text class="ai-name">AI 外教</text>
          <text class="ai-status">{{aiStatusText}}</text>
        </view>
      </view>

      <!-- AI语音播放条（外教真人录音） - 点击可重播 -->
      <view wx:if="{{currentQuestion.audioUrl}}" class="audio-bar" bindtap="playAudio">
        <view class="audio-play-btn">
          <image wx:if="{{!audioPlaying}}" class="audio-play-icon" src="/assets/icons/play.svg" mode="aspectFit" />
          <image wx:else class="audio-play-icon" src="/assets/icons/pause.svg" mode="aspectFit" />
        </view>
        <view class="audio-waves">
          <view wx:for="{{audioWaves}}" wx:key="index" class="audio-wave-bar {{audioPlaying ? 'playing' : ''}}" style="height: {{item}}rpx; animation-delay: {{index * 0.05}}s;"></view>
        </view>
      </view>

      <!-- AI评价反馈 -->
      <view wx:if="{{evaluationFeedback}}" class="feedback-area">
        <view class="feedback-score-row">
          <text class="feedback-label">得分</text>
          <text class="feedback-score" style="color: {{scoreColor}};">{{evaluationScore}}</text>
          <text class="feedback-passed {{evaluationPassed ? 'passed' : 'failed'}}">{{evaluationPassed ? '通过' : '未通过'}}</text>
        </view>
        <text class="feedback-text">{{evaluationFeedback}}</text>
      </view>
    </view>

    <!-- 升级提示 -->
    <view wx:if="{{showLevelUp}}" class="levelup-toast animate-fade-in">
      <text class="levelup-icon">🎉</text>
      <text class="levelup-text">升级！{{levelUpFrom}} → {{levelUpTo}}</text>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="bottom-bar">
    <!-- 状态：准备回答 / 录音中（含自动播放后进入） -->
    <view wx:if="{{phase === 'answering'}}" class="action-area">
      <view class="record-area">
        <view wx:if="{{isRecording}}" class="record-pulse-ring"></view>
        <view
          class="record-btn {{isRecording ? 'recording' : ''}}"
          bindtap="toggleRecording"
        >
          <image class="record-mic-icon" src="/assets/icons/mic-white.svg" mode="aspectFit" />
        </view>
        <text class="record-hint">{{isRecording ? '点击结束录音' : '点击开始录音'}}</text>
        <text wx:if="{{isRecording}}" class="record-timer">{{recordTimeDisplay}}</text>
      </view>
      <view class="skip-row">
        <button class="skip-btn" bindtap="handleSkip">跳过此题</button>
      </view>
    </view>

    <!-- 状态：正在播放AI语音（自动播放中，不可操作） -->
    <view wx:elif="{{phase === 'listening'}}" class="action-area">
      <view class="listening-hint-wrap">
        <view class="listening-dots">
          <view class="listening-dot"></view>
          <view class="listening-dot"></view>
          <view class="listening-dot"></view>
        </view>
        <text class="listening-hint-text">正在播放题目，请仔细听...</text>
      </view>
    </view>

    <!-- 状态：评估中 -->
    <view wx:elif="{{phase === 'evaluating'}}" class="action-area">
      <view class="evaluating-wrap">
        <view class="spinner"></view>
        <text class="evaluating-text">AI正在评估你的回答...</text>
      </view>
    </view>

    <!-- 状态：显示评价，等待下一题 / 查看结果 -->
    <view wx:elif="{{phase === 'feedback'}}" class="action-area">
      <button class="btn-primary" bindtap="handleNext">
        <text>{{nextButtonText}}</text>
      </button>
    </view>

    <!-- 状态：升级动画 -->
    <view wx:elif="{{phase === 'levelup'}}" class="action-area">
      <view class="evaluating-wrap">
        <text class="evaluating-text">正在加载下一级题目...</text>
      </view>
    </view>

    <!-- 状态：加载中 -->
    <view wx:elif="{{phase === 'loading'}}" class="action-area">
      <view class="evaluating-wrap">
        <view class="spinner"></view>
        <text class="evaluating-text">正在准备测评...</text>
      </view>
    </view>

    <!-- 状态：AI外教引导 -->
    <view wx:elif="{{phase === 'guide'}}" class="action-area guide-area">
      <!-- 引导气泡内容 -->
      <view class="guide-bubble-wrap">
        <!-- Step 1: 欢迎 -->
        <view wx:if="{{guideStep === 1}}" class="guide-bubble animate-fade-in">
          <text class="guide-emoji">👋</text>
          <text class="guide-title">你好！我是你的AI外教</text>
          <text class="guide-desc">接下来我会用英语和你对话，测出你的真实英语水平。很简单，跟着我的引导就好！</text>
          <view class="guide-btns">
            <button class="guide-btn-skip" bindtap="handleGuideSkip">跳过，直接开始</button>
            <button class="guide-btn-next" bindtap="handleGuideNext">了解一下</button>
          </view>
        </view>

        <!-- Step 2: 流程说明 -->
        <view wx:elif="{{guideStep === 2}}" class="guide-bubble animate-fade-in">
          <text class="guide-title">测评流程很简单</text>
          <view class="guide-steps">
            <view class="guide-step-item">
              <text class="guide-step-num">1</text>
              <text class="guide-step-text">听AI外教的英语提问</text>
            </view>
            <view class="guide-step-item">
              <text class="guide-step-num">2</text>
              <text class="guide-step-text">点击麦克风，用英语回答</text>
            </view>
            <view class="guide-step-item">
              <text class="guide-step-num">3</text>
              <text class="guide-step-text">答对了，AI出更难的题</text>
            </view>
            <view class="guide-step-item">
              <text class="guide-step-num">4</text>
              <text class="guide-step-text">直到测出你的真实水平</text>
            </view>
          </view>
          <view class="guide-btns">
            <button class="guide-btn-skip" bindtap="handleGuideSkip">跳过</button>
            <button class="guide-btn-next" bindtap="handleGuideNext">明白了</button>
          </view>
        </view>

        <!-- Step 3: 准备开始 -->
        <view wx:elif="{{guideStep === 3}}" class="guide-bubble animate-fade-in">
          <text class="guide-emoji">🌟</text>
          <text class="guide-title">准备好了吗？</text>
          <text class="guide-desc">请在安静的环境中进行，说话时靠近手机麦克风。不会的可以说 "I don't know" 或跳过。</text>
          <view class="guide-btns">
            <button class="guide-btn-start" bindtap="handleGuideStart">开始测评 →</button>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
