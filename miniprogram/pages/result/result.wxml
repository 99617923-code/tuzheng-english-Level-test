<!--
  途正英语分级测评 - 结果页（全新UI设计 v2）
  
  核心流程：
  1. 测评结束后显示本次测评结果（等级、得分、报告）
  2. 用户可以选择"重新测评"（不满意当前结果）
  3. 用户点击"确认最终评级"后，锁定结果
  4. 确认后不可更改
  
  布局优化：
  - 操作按钮放在首屏（hero-card下方）
  - 评价建议改为可折叠区域
  - 新增逐题分析区域（对接report接口）
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-right-placeholder"></view>
      <text class="nav-title-center">{{confirmed ? '最终测评报告' : (isPreview ? '测评报告（实时预览）' : '测评报告（预览）')}}</text>
      <view class="nav-back-btn" bindtap="goHome">
        <image class="nav-back-icon" src="/assets/icons/x.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap" style="padding-top: {{navBarHeight}}px;">
    <view class="loading-card">
      <view class="loading-rings">
        <view class="loading-ring ring-1"></view>
        <view class="loading-ring ring-2"></view>
        <view class="loading-ring ring-3"></view>
      </view>
      <text class="loading-title">正在生成测评报告</text>
      <text class="loading-desc">正在分析你的表现...</text>
    </view>
  </view>

  <!-- 结果内容 -->
  <scroll-view wx:else scroll-y class="scroll-area" style="top: {{navBarHeight}}px;" enhanced show-scrollbar="{{false}}">

    <!-- 预览状态提示条（测评未正式结束） -->
    <view wx:if="{{isPreview && !confirmed}}" class="confirm-banner animate-fade-in" style="background: linear-gradient(135deg, #fff3e0, #fff8e1); border-color: #ffb74d;">
      <view class="confirm-banner-icon">⚠️</view>
      <view class="confirm-banner-text">
        <text class="confirm-banner-title">测评尚未完成</text>
        <text class="confirm-banner-desc">当前显示的是实时预览数据，完成全部测评后将生成正式报告。</text>
      </view>
    </view>

    <!-- 未确认提示条（测评已正式结束） -->
    <view wx:if="{{!isPreview && !confirmed}}" class="confirm-banner animate-fade-in">
      <view class="confirm-banner-icon">💡</view>
      <view class="confirm-banner-text">
        <text class="confirm-banner-title">这是你的测评预览</text>
        <text class="confirm-banner-desc">如果觉得不够准确，可以重新测评。确认后将锁定评级，不可更改。</text>
      </view>
    </view>

    <!-- 已确认标记 -->
    <view wx:if="{{confirmed}}" class="confirmed-badge animate-fade-in">
      <text class="confirmed-badge-icon">✅</text>
      <text class="confirmed-badge-text">评级已确认，不可更改</text>
    </view>

    <!-- 等级展示头部 -->
    <view class="hero-card animate-fade-in">
      <view class="hero-bg" style="background: {{heroBgGradient}};"></view>
      <view class="hero-content">
        <!-- 等级徽章 -->
        <view class="hero-badge" style="background: {{levelColor}}; box-shadow: 0 8rpx 32rpx {{levelShadow}};">
          <text class="hero-badge-text">{{levelName}}</text>
        </view>
        <text wx:if="{{highestSubLevel}}" class="hero-sublevel">最高通过：{{highestSubLevel}}</text>

        <!-- 综合得分 - 圆环 -->
        <view class="score-ring-wrap">
          <view class="score-ring">
            <view class="score-ring-bg"></view>
            <view class="score-ring-fill" style="background: conic-gradient({{levelColor}} {{scorePercent}}%, transparent {{scorePercent}}%);"></view>
            <view class="score-ring-inner">
              <text class="score-number">{{overallScore}}</text>
              <text class="score-unit">分</text>
            </view>
          </view>
        </view>

        <!-- 测评数据 -->
        <view class="hero-stats">
          <view class="hero-stat">
            <text class="hero-stat-value">{{totalQuestions}}</text>
            <text class="hero-stat-label">答题数</text>
          </view>
          <view class="hero-stat-line"></view>
          <view class="hero-stat">
            <text class="hero-stat-value">{{passedQuestions}}</text>
            <text class="hero-stat-label">通过数</text>
          </view>
          <view class="hero-stat-line"></view>
          <view class="hero-stat">
            <text class="hero-stat-value">{{durationText}}</text>
            <text class="hero-stat-label">用时</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ★ 操作按钮区 - 放在首屏（hero-card下方） -->
    <view class="actions animate-fade-in-delay-1">
      <!-- 未确认状态 -->
      <view wx:if="{{!confirmed}}">
        <!-- 预览状态：测评未完成，不能确认评级 -->
        <view wx:if="{{isPreview}}">
          <button class="action-btn-full confirm-btn" style="opacity: 0.5;" bindtap="handleConfirmLevel">
            <text>✓ 确认最终评级</text>
          </button>
          <view style="text-align: center; font-size: 24rpx; color: #999; margin-top: -16rpx; margin-bottom: 20rpx;">测评未完成，完成后可确认</view>
          <view class="action-row-inline">
            <button class="action-btn-half retake-btn" bindtap="handleRetake">
              <text>重新测评</text>
            </button>
            <button class="action-btn-half home-btn" bindtap="goHome">
              <text>返回首页</text>
            </button>
          </view>
        </view>
        <!-- 正式状态：测评已完成，可以确认评级 -->
        <view wx:else>
          <button class="action-btn-full confirm-btn" bindtap="handleConfirmLevel">
            <text>✓ 确认最终评级</text>
          </button>
          <view class="action-row-inline">
            <button class="action-btn-half retake-btn" bindtap="handleRetake">
              <text>重新测评</text>
            </button>
            <button class="action-btn-half home-btn" bindtap="goHome">
              <text>返回首页</text>
            </button>
          </view>
        </view>
      </view>

      <!-- 已确认状态：显示分享等操作 -->
      <view wx:if="{{confirmed}}">
        <view class="action-row-three">
          <button class="action-btn-third share-btn-mini" open-type="share">
            <text>分享</text>
          </button>
          <button class="action-btn-third poster-btn-mini" bindtap="savePoster" disabled="{{posterSaving}}">
            <text>{{posterSaving ? '生成中...' : '保存海报'}}</text>
          </button>
          <button class="action-btn-third home-btn-mini" bindtap="goHome">
            <text>回首页</text>
          </button>
        </view>
      </view>
    </view>

    <!-- ★ 报告Tab切换栏 -->
    <view class="report-tabs animate-fade-in-delay-2">
      <view class="report-tab-bar">
        <view class="report-tab-item {{activeReportTab === 'summary' ? 'active' : ''}}" data-tab="summary" bindtap="switchReportTab">
          <text class="report-tab-text">综合报告</text>
        </view>
        <view class="report-tab-item {{activeReportTab === 'intro' ? 'active' : ''}}" data-tab="intro" bindtap="switchReportTab">
          <text class="report-tab-text">个人介绍</text>
        </view>
        <view class="report-tab-item {{activeReportTab === 'questions' ? 'active' : ''}}" data-tab="questions" bindtap="switchReportTab">
          <text class="report-tab-text">逐题分析</text>
        </view>
      </view>
    </view>

    <!-- ★ Tab内容：个人介绍测评报告 -->
    <view wx:if="{{activeReportTab === 'intro' && selfIntroReport}}" class="report-tab-content animate-fade-in">
      <view class="detail-section">
        <view class="detail-content">
        <!-- 预估级别范围 -->
        <view wx:if="{{selfIntroReport.levelRange}}" class="si-level-card">
          <view class="si-level-header">
            <text class="si-level-label">预估英语口语级别</text>
          </view>
          <view class="si-level-range">
            <text class="si-level-value">{{selfIntroReport.levelRange}}</text>
            <text wx:if="{{selfIntroReport.levelRangeNames}}" class="si-level-names">{{selfIntroReport.levelRangeNames}}</text>
          </view>
        </view>

        <!-- 录音回放 -->
        <view wx:if="{{selfIntroReport.audioUrl}}" class="si-audio-card">
          <view class="si-audio-header">
            <text class="si-audio-title">🎤 我的录音</text>
            <text wx:if="{{selfIntroReport.durationText}}" class="si-audio-duration">{{selfIntroReport.durationText}}</text>
          </view>
          <view class="si-audio-player" bindtap="playSelfIntroAudio">
            <view class="si-play-btn {{playingAudioUrl === selfIntroReport.audioUrl ? 'playing' : ''}}">
              <text class="si-play-icon">{{playingAudioUrl === selfIntroReport.audioUrl ? '■' : '▶'}}</text>
            </view>
            <view class="si-audio-wave">
              <view class="si-wave-bar" wx:for="{{20}}" wx:key="index" style="animation-delay: {{index * 0.05}}s; height: {{playingAudioUrl === selfIntroReport.audioUrl ? '100%' : '30%'}};"></view>
            </view>
            <text class="si-play-text">{{playingAudioUrl === selfIntroReport.audioUrl ? '停止播放' : '播放录音'}}</text>
          </view>
        </view>

        <!-- 英文文本转写（支持高亮标注） -->
        <view wx:if="{{selfIntroReport.transcription}}" class="si-text-card">
          <view class="si-text-header">
            <text class="si-text-title">📝 英文转写</text>
            <view class="si-text-badges">
              <text wx:if="{{selfIntroReport.errorCount > 0}}" class="si-badge si-badge-error">{{selfIntroReport.errorCount}} 个语法问题</text>
              <text wx:if="{{selfIntroReport.highlightCount > 0}}" class="si-badge si-badge-good">✨ {{selfIntroReport.highlightCount}} 个亮点</text>
              <text wx:if="{{selfIntroReport.wordCount > 0}}" class="si-word-count">{{selfIntroReport.wordCount}} 词</text>
            </view>
          </view>
          <view class="si-text-content">
            <!-- 有高亮标注时用片段渲染 -->
            <view wx:if="{{selfIntroReport.hasHighlights}}" class="si-transcription-hl">
              <text
                wx:for="{{selfIntroReport.textSegments}}"
                wx:key="id"
                class="si-seg si-seg-{{item.type}}"
                data-seg="{{item}}"
                bindtap="onHighlightTap"
              >{{item.text}}</text>
            </view>
            <!-- 无高亮时显示纯文本 -->
            <text wx:else class="si-transcription">{{selfIntroReport.transcription}}</text>
          </view>
          <!-- 高亮详情气泡 -->
          <view wx:if="{{activeHighlight}}" class="si-hl-bubble" catchtap="closeHighlightBubble">
            <view class="si-hl-bubble-inner" catchtap="">
              <view class="si-hl-bubble-header">
                <text class="si-hl-bubble-word si-hl-word-{{activeHighlight.type}}">{{activeHighlight.text}}</text>
                <text class="si-hl-bubble-type si-hl-type-{{activeHighlight.type}}">{{activeHighlight.type === 'error' ? '语法问题' : '表达亮点'}}</text>
              </view>
              <view wx:if="{{activeHighlight.type === 'error' && activeHighlight.suggestion}}" class="si-hl-suggestion">
                <text class="si-hl-suggestion-label">建议改为：</text>
                <text class="si-hl-suggestion-text">{{activeHighlight.suggestion}}</text>
              </view>
              <view wx:if="{{activeHighlight.reason}}" class="si-hl-reason">
                <text class="si-hl-reason-text">{{activeHighlight.reason}}</text>
              </view>
              <view class="si-hl-bubble-close" bindtap="closeHighlightBubble">
                <text>我知道了</text>
              </view>
            </view>
          </view>
          <!-- 图例 -->
          <view wx:if="{{selfIntroReport.hasHighlights}}" class="si-text-legend">
            <view class="si-legend-item">
              <view class="si-legend-dot si-legend-error"></view>
              <text class="si-legend-label">语法问题</text>
            </view>
            <view class="si-legend-item">
              <view class="si-legend-dot si-legend-good"></view>
              <text class="si-legend-label">表达亮点</text>
            </view>
            <text class="si-legend-tip">点击标注词查看详情</text>
          </view>
        </view>

        <!-- 五维度能力分析 -->
        <view wx:if="{{selfIntroReport.hasDimensions}}" class="si-dims-card">
          <view class="si-dims-header">
            <text class="si-dims-title">📊 能力维度分析</text>
          </view>
          <view class="si-dims-list">
            <view class="si-dim-item" wx:for="{{selfIntroReport.dimensions}}" wx:key="name">
              <view class="si-dim-row">
                <text class="si-dim-name">{{item.name}}</text>
                <text class="si-dim-score" style="color: {{item.color}};">{{item.score}}分</text>
              </view>
              <view class="si-dim-bar-track">
                <view class="si-dim-bar-fill" style="width: {{item.score}}%; background: {{item.color}};"></view>
              </view>
              <text wx:if="{{item.comment}}" class="si-dim-comment">{{item.comment}}</text>
            </view>
          </view>
        </view>

        <!-- 综合评价 -->
        <view wx:if="{{selfIntroReport.overallComment}}" class="si-comment-card">
          <view class="si-comment-header">
            <text class="si-comment-title">💬 综合评价</text>
          </view>
          <view class="si-comment-content">
            <text class="si-comment-text">{{selfIntroReport.overallComment}}</text>
          </view>
        </view>
        </view>
      </view>
    </view>

    <!-- ★ Tab内容：逐题分析 -->
    <view wx:if="{{activeReportTab === 'questions' && questionDetails.length > 0}}" class="report-tab-content animate-fade-in">
      <view class="detail-section">
        <view class="report-tab-section-header">
          <text class="report-tab-section-title">逐题分析（{{questionDetails.length}}题）</text>
        </view>
        <view class="detail-content">
        <view class="question-detail-list">
          <view class="question-detail-item" wx:for="{{questionDetails}}" wx:key="index" wx:for-index="qIdx">
            <!-- 题号头部（可点击展开） -->
            <view class="qd-header" data-idx="{{qIdx}}" bindtap="toggleQuestionExpand">
              <view class="qd-index-wrap">
                <text class="qd-index">第{{item.index}}题</text>
                <text wx:if="{{item.subLevelName}}" class="qd-sublevel">{{item.subLevelName}}</text>
                <text class="qd-passed {{item.passed ? 'passed' : 'failed'}}">{{item.passedText}}</text>
              </view>
              <view class="qd-score-wrap">
                <text class="qd-score" style="color: {{item.scoreColor}};">{{item.score}}分</text>
                <view class="qd-expand-arrow {{item.expanded ? 'expanded' : ''}}">
                  <image class="qd-expand-icon" src="/assets/icons/chevron-down-dark.svg" mode="aspectFit" />
                </view>
              </view>
            </view>

            <!-- 题目内容（始终显示） -->
            <view wx:if="{{item.questionText}}" class="qd-question">
              <text class="qd-label">🎙️ 题目：</text>
              <text class="qd-text">{{item.questionText}}</text>
              <view wx:if="{{item.audioUrl}}" class="qd-audio-btn" data-url="{{item.audioUrl}}" bindtap="playQuestionAudio">
                <text class="qd-audio-text">▶ 听题</text>
              </view>
            </view>

            <!-- 用户回答（始终显示） -->
            <view class="qd-answer">
              <text class="qd-label">💬 你的回答：</text>
              <text class="qd-text {{item.userAnswer === '（未作答）' ? 'qd-no-answer' : ''}}">{{item.userAnswer}}</text>
            </view>

            <!-- 用户录音回放（独立行，醒目显示） -->
            <view wx:if="{{item.userAudioUrl}}" class="qd-user-audio-row" data-url="{{item.userAudioUrl}}" bindtap="playUserAudio">
              <text class="qd-audio-label">🎤 我的录音</text>
              <view class="qd-play-btn {{playingAudioUrl === item.userAudioUrl ? 'playing' : ''}}">
                <text>{{playingAudioUrl === item.userAudioUrl ? '■ 停止播放' : '▶ 播放录音'}}</text>
              </view>
            </view>

            <!-- 展开详情：四维度评分 + AI解析 -->
            <view wx:if="{{item.expanded}}" class="qd-detail-expand">
              <!-- 四维度评分 -->
              <view wx:if="{{item.hasScoreDetail}}" class="qd-score-detail">
                <text class="qd-detail-title">📊 分项评分</text>
                <view class="qd-score-bars">
                  <view wx:if="{{item.scoreDetail.pronunciation !== null}}" class="qd-bar-item">
                    <text class="qd-bar-label">发音</text>
                    <view class="qd-bar-track">
                      <view class="qd-bar-fill" style="width: {{item.scoreDetail.pronunciation}}%; background: #3b82f6;"></view>
                    </view>
                    <text class="qd-bar-value">{{item.scoreDetail.pronunciation}}</text>
                  </view>
                  <view wx:if="{{item.scoreDetail.grammar !== null}}" class="qd-bar-item">
                    <text class="qd-bar-label">语法</text>
                    <view class="qd-bar-track">
                      <view class="qd-bar-fill" style="width: {{item.scoreDetail.grammar}}%; background: #22c55e;"></view>
                    </view>
                    <text class="qd-bar-value">{{item.scoreDetail.grammar}}</text>
                  </view>
                  <view wx:if="{{item.scoreDetail.vocabulary !== null}}" class="qd-bar-item">
                    <text class="qd-bar-label">词汇</text>
                    <view class="qd-bar-track">
                      <view class="qd-bar-fill" style="width: {{item.scoreDetail.vocabulary}}%; background: #f59e0b;"></view>
                    </view>
                    <text class="qd-bar-value">{{item.scoreDetail.vocabulary}}</text>
                  </view>
                  <view wx:if="{{item.scoreDetail.fluency !== null}}" class="qd-bar-item">
                    <text class="qd-bar-label">流利</text>
                    <view class="qd-bar-track">
                      <view class="qd-bar-fill" style="width: {{item.scoreDetail.fluency}}%; background: #8b5cf6;"></view>
                    </view>
                    <text class="qd-bar-value">{{item.scoreDetail.fluency}}</text>
                  </view>
                  <view wx:if="{{item.scoreDetail.relevance !== null}}" class="qd-bar-item">
                    <text class="qd-bar-label">相关性</text>
                    <view class="qd-bar-track">
                      <view class="qd-bar-fill" style="width: {{item.scoreDetail.relevance}}%; background: #ec4899;"></view>
                    </view>
                    <text class="qd-bar-value">{{item.scoreDetail.relevance}}</text>
                  </view>
                </view>
              </view>

              <!-- AI解析 -->
              <view wx:if="{{item.feedback}}" class="qd-ai-analysis">
                <text class="qd-detail-title">🤖 AI解析</text>
                <text class="qd-analysis-text">{{item.feedback}}</text>
              </view>

              <!-- 改进建议 -->
              <view wx:if="{{item.suggestion}}" class="qd-suggestion-box">
                <text class="qd-detail-title">💡 改进建议</text>
                <text class="qd-suggestion-text">{{item.suggestion}}</text>
              </view>
            </view>
          </view>
        </view>
        </view>
      </view>
    </view>

    <!-- ★ Tab内容：综合报告 -->
    <view wx:if="{{activeReportTab === 'summary'}}" class="report-tab-content animate-fade-in">
      <view class="detail-section">
        <view class="detail-content">
        <!-- 分项得分 -->
        <view wx:if="{{scoreItems.length > 0}}" class="section">
          <view class="section-header">
            <view class="section-icon-wrap green">
              <image class="section-icon" src="/assets/icons/bar-chart-green.svg" mode="aspectFit" />
            </view>
            <text class="section-title">分项得分</text>
          </view>
          <view class="content-card">
            <view class="score-item" wx:for="{{scoreItems}}" wx:key="label">
              <view class="score-row">
                <text class="score-label">{{item.label}}</text>
                <text class="score-val" style="color: {{item.color}};">{{item.value}}</text>
              </view>
              <view class="score-track">
                <view class="score-fill" style="width: {{item.percent}}%; background: {{item.color}};"></view>
              </view>
            </view>
          </view>
        </view>

        <!-- 能力评估 -->
        <view class="section">
          <view class="section-header">
            <view class="section-icon-wrap blue">
              <image class="section-icon" src="/assets/icons/zap-blue.svg" mode="aspectFit" />
            </view>
            <text class="section-title">能力评估</text>
          </view>
          <view class="content-card">
            <text class="desc-text">{{summary}}</text>
          </view>
        </view>

        <!-- 优势 -->
        <view wx:if="{{strengths.length > 0}}" class="section">
          <view class="section-header">
            <view class="section-icon-wrap green">
              <image class="section-icon" src="/assets/icons/check-circle-green.svg" mode="aspectFit" />
            </view>
            <text class="section-title">你的优势</text>
          </view>
          <view class="content-card">
            <view class="tag-list strength" wx:for="{{strengths}}" wx:key="index">
              <view class="tag-dot green"></view>
              <text class="tag-text">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 待提升 -->
        <view wx:if="{{weaknesses.length > 0}}" class="section">
          <view class="section-header">
            <view class="section-icon-wrap orange">
              <image class="section-icon" src="/assets/icons/trending-up-orange.svg" mode="aspectFit" />
            </view>
            <text class="section-title">待提升</text>
          </view>
          <view class="content-card">
            <view class="tag-list weakness" wx:for="{{weaknesses}}" wx:key="index">
              <view class="tag-dot orange"></view>
              <text class="tag-text">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 学习建议 -->
        <view class="section">
          <view class="section-header">
            <view class="section-icon-wrap blue">
              <image class="section-icon" src="/assets/icons/award-blue.svg" mode="aspectFit" />
            </view>
            <text class="section-title">学习建议</text>
          </view>
          <view class="recommend-card">
            <text class="recommend-text">{{recommendation}}</text>
          </view>
        </view>
        </view>
      </view>
    </view>

    <!-- 底部间距 -->
    <view style="height: calc(env(safe-area-inset-bottom) + 48rpx);"></view>
  </scroll-view>

  <!-- 离屏Canvas用于绘制海报 -->
  <canvas type="2d" id="posterCanvas" style="position: fixed; left: -9999px; top: -9999px; width: 750px; height: 1200px;"></canvas>


</view>
