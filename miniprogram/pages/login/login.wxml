<!--
  途正英语AI分级测评 - 登录页
  手机号 + 短信验证码登录
-->
<view class="page">
  <!-- 顶部渐变装饰区 -->
  <view class="header-bg">
    <view class="header-deco-1"></view>
    <view class="header-deco-2"></view>
    <view class="header-content">
      <image class="avatar" src="{{aiAvatarUrl}}" mode="aspectFill" />
      <image class="header-logo" src="{{logoUrl}}" mode="heightFix" />
      <text class="header-subtitle">AI智能英语水平测评</text>
    </view>
    <!-- 底部波浪 -->
    <view class="wave-bottom"></view>
  </view>

  <!-- 登录表单 -->
  <view class="form-wrap">
    <view class="form-card glass-card-strong">
      <text class="form-title">手机号快捷登录</text>
      <text class="form-desc">未注册的手机号将自动创建账号</text>

      <!-- 手机号输入 -->
      <view class="input-group">
        <view class="input-wrap">
          <image class="input-icon" src="/assets/icons/phone.svg" mode="aspectFit" />
          <input
            type="number"
            placeholder="请输入手机号"
            maxlength="11"
            value="{{phone}}"
            bindinput="onPhoneInput"
            class="input-field"
          />
        </view>
      </view>

      <!-- 验证码输入 -->
      <view class="input-group">
        <view class="code-row">
          <view class="input-wrap code-input-wrap">
            <image class="input-icon" src="/assets/icons/shield-check.svg" mode="aspectFit" />
            <input
              type="number"
              placeholder="请输入验证码"
              maxlength="6"
              value="{{smsCode}}"
              bindinput="onCodeInput"
              bindconfirm="handleLogin"
              class="input-field"
            />
          </view>
          <button
            class="send-code-btn {{countdown > 0 ? 'disabled' : ''}}"
            bindtap="handleSendCode"
            disabled="{{sendingCode || countdown > 0}}"
          >
            <text wx:if="{{sendingCode}}" class="sending-text">发送中...</text>
            <text wx:elif="{{countdown > 0}}" class="countdown-text">{{countdown}}s 后重发</text>
            <text wx:else class="send-text">获取验证码</text>
          </button>
        </view>
      </view>

      <!-- 登录按钮 -->
      <button class="login-btn" bindtap="handleLogin" disabled="{{loading}}">
        <text wx:if="{{loading}}" class="login-btn-text">登录中...</text>
        <text wx:else class="login-btn-text">登录</text>
      </button>

      <!-- 协议提示 -->
      <text class="agreement">登录即表示同意《用户服务协议》和《隐私政策》</text>
    </view>

    <!-- 底部品牌 -->
    <view class="brand-footer">
      <image class="brand-logo" src="{{logoUrl}}" mode="heightFix" />
    </view>
  </view>
</view>
