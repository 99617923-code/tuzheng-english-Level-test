<!--
  途正英语AI分级测评 - 登录页
  小程序原生适配：微信快捷登录 + 手机号验证码登录
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="goBack">
        <image class="nav-back-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
      </view>
      <text class="nav-title-center">登录</text>
      <view class="nav-right-placeholder"></view>
    </view>
  </view>

  <!-- 主内容 -->
  <view class="content" style="padding-top: {{navBarHeight}}px;">
    <!-- 品牌区域 -->
    <view class="brand-area">
      <image class="brand-logo" src="{{logoUrl}}" mode="aspectFit" />
      <text class="brand-subtitle">智能英语口语水平测评</text>
    </view>

    <!-- 登录方式 -->
    <view class="login-area">
      <!-- 微信一键登录（推荐） -->
      <view class="wx-login-section">
        <button class="wx-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          <text class="wx-login-text">微信手机号快捷登录</text>
        </button>
        <text class="wx-login-hint">推荐使用，无需输入手机号</text>
      </view>

      <!-- 分割线 -->
      <view class="divider-row">
        <view class="divider-line"></view>
        <text class="divider-text">或</text>
        <view class="divider-line"></view>
      </view>

      <!-- 手机号验证码登录 -->
      <view class="sms-login-section">
        <view wx:if="{{!showSmsForm}}" class="sms-toggle" bindtap="toggleSmsForm">
          <text class="sms-toggle-text">使用手机号验证码登录</text>
        </view>

        <view wx:else class="sms-form">
          <!-- 手机号输入 -->
          <view class="input-group">
            <view class="input-wrap">
              <image class="input-icon" src="/assets/icons/phone.svg" mode="aspectFit" />
              <input
                type="number"
                placeholder="请输入手机号"
                maxlength="11"
                value="{{phone}}"
                bindinput="onPhoneInput"
                class="input-field"
              />
            </view>
          </view>

          <!-- 验证码输入 -->
          <view class="input-group">
            <view class="code-row">
              <view class="input-wrap code-input-wrap">
                <image class="input-icon" src="/assets/icons/shield-check.svg" mode="aspectFit" />
                <input
                  type="number"
                  placeholder="请输入验证码"
                  maxlength="6"
                  value="{{smsCode}}"
                  bindinput="onCodeInput"
                  bindconfirm="handleSmsLogin"
                  class="input-field"
                />
              </view>
              <button
                class="send-code-btn {{countdown > 0 ? 'disabled' : ''}}"
                bindtap="handleSendCode"
                disabled="{{sendingCode || countdown > 0}}"
              >
                <text wx:if="{{sendingCode}}" class="code-btn-text">发送中...</text>
                <text wx:elif="{{countdown > 0}}" class="code-btn-text">{{countdown}}s</text>
                <text wx:else class="code-btn-text">获取验证码</text>
              </button>
            </view>
          </view>

          <!-- 登录按钮 -->
          <button class="sms-login-btn" bindtap="handleSmsLogin" disabled="{{loading}}">
            <text wx:if="{{loading}}" class="sms-btn-text">登录中...</text>
            <text wx:else class="sms-btn-text">登录</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 协议勾选 -->
    <view class="agreement">
      <view class="agreement-checkbox" bindtap="toggleAgreement">
        <view class="checkbox-icon {{agreedPolicy ? 'checked' : ''}}">
          <image wx:if="{{agreedPolicy}}" class="check-mark" src="/assets/icons/check-white.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="agreement-content">
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="viewUserAgreement">《用户服务协议》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" bindtap="viewPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>
  </view>
</view>
