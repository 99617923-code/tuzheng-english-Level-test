<!--
  途正英语AI分级测评 - 欢迎页
  极简流程：点击"开始测评" → 自动授权 → 直接进入测评
  讲解视频从后台动态获取，无视频时不展示
-->
<view class="page">
  <!-- 装饰性背景元素 -->
  <view class="deco-circle deco-1"></view>
  <view class="deco-circle deco-2"></view>
  <view class="deco-circle deco-3"></view>

  <!-- 主内容 -->
  <view class="content" style="padding-top: {{navBarHeight}}px;">
    <!-- Logo区域（与胶囊按钮同行） -->
    <view class="logo-row" style="position:fixed; top:0; left:0; right:0; z-index:50; height:{{navBarHeight}}px; padding-top:{{navContentTop}}px;">
      <view class="logo-inner" style="height:{{navContentHeight}}px; padding-right:{{menuButtonRight}}px;">
        <image class="logo-img" src="{{logoUrl}}" mode="heightFix" />
      </view>
    </view>

    <!-- 问候语 -->
    <view class="greeting-area animate-fade-in">
      <text wx:if="{{isAuthenticated && userInfo}}" class="greeting">Hi, {{userInfo.nickname || '同学'}}</text>
    </view>

    <!-- Hero 标题 -->
    <view class="hero animate-fade-in-delay-1">
      <text class="title-line1">英语水平</text>
      <text class="title-line2">智能测评</text>
      <text class="subtitle">和外教对话，精准测评你的英语口语水平</text>
    </view>

    <!-- 核心CTA区域 -->
    <view wx:if="{{!levelConfirmed}}" class="cta-hero animate-fade-in-delay-1">
      <view class="start-btn-wrap">
        <view class="start-pulse-ring"></view>
        <view class="start-pulse-ring delay-1"></view>
        <button class="btn-start" bindtap="handleStart">开始测评</button>
      </view>
      <text class="cta-sub-hint">
        <text wx:if="{{recordAuthorized}}">✓ 录音权限已就绪</text>
        <text wx:else>点击后将请求录音权限</text>
      </text>
    </view>

    <!-- 已确认分级状态展示 -->
    <view wx:if="{{levelConfirmed}}" class="confirmed-hero animate-fade-in-delay-1">
      <view class="confirmed-badge-wrap">
        <view class="confirmed-badge">
          <text class="confirmed-badge-icon">✓</text>
        </view>
      </view>
      <text class="confirmed-title">分级已确认</text>
      <view class="confirmed-level-pill" style="border-color: {{confirmedLevelColor}}; color: {{confirmedLevelColor}};">
        <text>{{confirmedLevelName}}</text>
      </view>
      <text class="confirmed-hint">你已完成分级测评，无法再次测评</text>
      <view class="confirmed-actions">
        <view class="confirmed-btn confirmed-btn-result" bindtap="handleViewConfirmedResult">查看测评报告</view>
      </view>
    </view>

    <!-- 未完成测评恢复提示 -->
    <view wx:if="{{hasUnfinishedTest}}" class="resume-banner animate-fade-in-delay-2">
      <view class="resume-banner-inner glass-card-strong">
        <view class="resume-close-btn" bindtap="handleDismissResume">×</view>
        <view class="resume-info">
          <view class="resume-dot-pulse"></view>
          <view class="resume-text-wrap">
            <text class="resume-title">有未完成的测评</text>
            <text class="resume-desc">{{unfinishedInfo}}</text>
          </view>
        </view>
        <view class="resume-actions">
          <view class="resume-btn-continue" bindtap="handleResume">继续</view>
          <view class="resume-btn-discard" bindtap="handleDiscardTest">放弃</view>
        </view>
      </view>
    </view>

    <!-- 讲解视频（动态从后台获取，有视频且未确认分级才展示） -->
    <view wx:if="{{hasIntroVideo && !levelConfirmed}}" class="video-card glass-card animate-fade-in-delay-2" bindtap="handlePlayDemo">
      <view class="video-thumb-wrap">
        <image wx:if="{{introCoverUrl}}" class="video-thumb" src="{{introCoverUrl}}" mode="aspectFill" />
        <view wx:else class="video-thumb-placeholder">
          <view class="video-wave-bar" wx:for="{{waveHeights}}" wx:key="index" style="height: {{item}}rpx;"></view>
        </view>
        <view class="video-play-btn">
          <view class="play-triangle"></view>
        </view>
      </view>
      <view class="video-info">
        <text class="video-title">观看测评示例</text>
        <text class="video-desc">了解测评流程，轻松上手</text>
      </view>
    </view>

    <!-- 查看测评记录 -->
    <view class="history-entry glass-card animate-fade-in-delay-3" bindtap="goHistory">
      <view class="history-left">
        <view class="history-icon-wrap">
          <image class="history-icon" src="/assets/icons/history.svg" mode="aspectFit" />
        </view>
        <text class="history-text">查看测评记录</text>
      </view>
      <text class="history-arrow">›</text>
    </view>

    <!-- 弹性空间 -->
    <view class="flex-spacer"></view>

    <!-- 底部提示 -->
    <view class="bottom-hint">
      <text class="hint-text">测评约需5分钟 · 请在安静环境中进行</text>
    </view>
  </view>

  <!-- 未完成测评恢复弹窗（自定义弹窗，带关闭按钮） -->
  <view wx:if="{{showResumeModal}}" class="resume-modal-mask" bindtap="handleResumeModalClose">
    <view class="resume-modal-card" catchtap="preventClose">
      <!-- 关闭按钮 -->
      <view class="resume-modal-close" bindtap="handleResumeModalClose">
        <text class="resume-modal-close-icon">✕</text>
      </view>
      <!-- 标题 -->
      <view class="resume-modal-header">
        <view class="resume-modal-dot"></view>
        <text class="resume-modal-title">发现未完成的测评</text>
      </view>
      <!-- 内容 -->
      <text class="resume-modal-desc">你有一次未完成的测评（已答 {{resumeModalAnswered}} 题，当前级别 {{resumeModalSubLevel}}），是否继续？</text>
      <!-- 按钮 -->
      <view class="resume-modal-actions">
        <view class="resume-modal-btn resume-modal-btn-restart" bindtap="handleResumeModalRestart">重新开始</view>
        <view class="resume-modal-btn resume-modal-btn-continue" bindtap="handleResumeModalContinue">继续测评</view>
      </view>
    </view>
  </view>



  <!-- 模式选择弹窗（v1.3.0 AI智能跳级） -->
  <view wx:if="{{showModeModal}}" class="resume-modal-mask" bindtap="handleCloseModeModal">
    <view class="mode-modal-card" catchtap="preventClose">
      <!-- 关闭按钮 -->
      <view class="resume-modal-close" bindtap="handleCloseModeModal">
        <text class="resume-modal-close-icon">✕</text>
      </view>
      <!-- 标题 -->
      <view class="mode-modal-header">
        <text class="mode-modal-title">选择测评模式</text>
        <text class="mode-modal-subtitle">请根据你的英语基础选择合适的模式</text>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{loadingModes}}" class="mode-loading">
        <view class="spinner"></view>
        <text class="mode-loading-text">加载中...</text>
      </view>

      <!-- 模式卡片列表 -->
      <view wx:else class="mode-list">
        <view
          wx:for="{{evaluateModes}}"
          wx:key="mode"
          class="mode-card {{selectedMode === item.mode ? 'mode-card-selected' : ''}} {{item.mode === 'ai_smart' ? 'mode-card-ai' : ''}}"
          data-mode="{{item.mode}}"
          bindtap="handleSelectMode"
        >
          <!-- 选中指示器 -->
          <view class="mode-radio {{selectedMode === item.mode ? 'mode-radio-checked' : ''}}">
            <view wx:if="{{selectedMode === item.mode}}" class="mode-radio-dot"></view>
          </view>
          <view class="mode-card-content">
            <view class="mode-card-title-row">
              <text class="mode-card-name">{{item.name}}</text>
              <text wx:if="{{item.mode === 'ai_smart'}}" class="mode-card-badge">推荐有基础的同学</text>
            </view>
            <text class="mode-card-desc">{{item.description}}</text>
            <view class="mode-tips-list">
              <view wx:for="{{item.tips}}" wx:for-item="tip" wx:key="*this" class="mode-tip-item">
                <text class="mode-tip-dot">•</text>
                <text class="mode-tip-text">{{tip}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 确认按钮 -->
      <view wx:if="{{!loadingModes}}" class="mode-modal-actions">
        <button class="mode-confirm-btn" bindtap="handleConfirmMode">开始测评</button>
      </view>
    </view>
  </view>

  <!-- 视频播放弹窗 -->
  <view wx:if="{{showVideo}}" class="video-modal" bindtap="closeVideo">
    <view class="video-modal-content {{isVerticalVideo ? 'video-vertical' : 'video-horizontal'}}" catchtap="preventClose">
      <video
        class="video-player"
        src="{{introVideoUrl}}"
        poster="{{introCoverUrl}}"
        autoplay="{{true}}"
        show-center-play-btn="{{true}}"
        show-play-btn="{{true}}"
        controls="{{true}}"
        enable-progress-gesture="{{true}}"
        bindloadedmetadata="onVideoMetaLoaded"
      />
      <view class="video-close-btn" bindtap="closeVideo">
        <text class="close-icon">✕</text>
      </view>
    </view>
  </view>
</view>
