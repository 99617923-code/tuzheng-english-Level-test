/* 途正英语 - 测评说明页样式（简化版，一屏显示） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(240,244,248,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.6);
}

.nav-back-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nav-placeholder {
  width: 64rpx;
}

/* 主体内容 - 不用scroll-view，直接flex布局 */
.body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
}

/* AI老师卡片 - 更紧凑 */
.teacher-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(27,63,145,0.10);
  flex-shrink: 0;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--brand-blue);
  margin-bottom: 4rpx;
}

.teacher-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

/* Section - 更紧凑间距 */
.section {
  margin-bottom: 28rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* Steps - 更紧凑 */
.steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.step-num-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-num {
  font-size: 24rpx;
  font-weight: 800;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.step-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Tips - 更紧凑 */
.tips-card {
  padding: 24rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* Permission - 紧凑横排 */
.permission-card {
  padding: 24rpx;
  margin-bottom: 28rpx;
  border-radius: var(--radius-card);
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 2rpx solid rgba(27,63,145,0.12);
}

.permission-granted-card {
  background: rgba(131,186,18,0.06);
  border: 2rpx solid rgba(131,186,18,0.30);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.permission-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.permission-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(27,63,145,0.08);
  flex-shrink: 0;
}

.permission-icon-wrap.icon-granted {
  background: rgba(131,186,18,0.15);
}

.permission-icon {
  width: 36rpx;
  height: 36rpx;
}

.permission-info {
  flex: 1;
}

.permission-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.permission-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 2rpx;
}

.permission-status {
  margin-top: 16rpx;
  text-align: center;
}

.status-granted {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-green);
}

.permission-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1B3F91, #2B5BA0) !important;
  color: #ffffff !important;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-full) !important;
  padding: 12rpx 48rpx !important;
  line-height: 1.4;
  border: none;
}

.permission-btn::after {
  border: none;
}

/* Bottom */
.bottom-area {
  margin-top: auto;
  padding-top: 20rpx;
}

.btn-disabled {
  background: #c0c8d5 !important;
  box-shadow: none !important;
}

.bottom-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 16rpx;
}
