/* 途正英语 - 测评报告页样式（v2 布局优化） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 滚动区 - 修复右侧贴边 */
.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 36rpx;
  padding-top: 24rpx;
  box-sizing: border-box;
}

/* ========== 加载状态 ========== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 48rpx;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.loading-rings {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 40rpx;
}

.loading-ring {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid transparent;
  animation: spin 1.2s linear infinite;
}

.ring-1 {
  top: 0; left: 0; right: 0; bottom: 0;
  border-top-color: var(--brand-blue);
}

.ring-2 {
  top: 12rpx; left: 12rpx; right: 12rpx; bottom: 12rpx;
  border-right-color: var(--brand-green);
  animation-duration: 1.6s;
  animation-direction: reverse;
}

.ring-3 {
  top: 24rpx; left: 24rpx; right: 24rpx; bottom: 24rpx;
  border-bottom-color: var(--brand-blue-light);
  animation-duration: 2s;
}

.loading-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--brand-blue);
  margin-bottom: 12rpx;
}

.loading-desc {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* ========== 等级展示头部 ========== */
.hero-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: var(--radius-lg);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx 40rpx;
}

/* 等级徽章（自适应宽度，防止“途正口语X级”长文字撞出） */
.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  margin-bottom: 16rpx;
  max-width: 90%;
  box-sizing: border-box;
}

.hero-badge-text {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

.hero-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.hero-sublevel {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
  padding: 4rpx 20rpx;
  background: rgba(59,130,246,0.05);
  border-radius: var(--radius-full);
}

/* 圆环得分 */
.score-ring-wrap {
  margin: 16rpx 0 32rpx;
}

.score-ring {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.score-ring-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(59,130,246,0.06);
}

.score-ring-fill {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  mask: radial-gradient(transparent 70rpx, black 70rpx);
  -webkit-mask: radial-gradient(transparent 70rpx, black 70rpx);
}

.score-ring-inner {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--text-primary);
  line-height: 1;
}

.score-unit {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* 测评数据 */
.hero-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding: 24rpx 32rpx;
  background: rgba(255,255,255,0.50);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.hero-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.hero-stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.hero-stat-line {
  width: 1rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.06);
}

/* ========== 操作按钮（首屏） ========== */
.actions {
  margin-bottom: 32rpx;
}

/* 全宽操作按钮 */
.action-btn-full {
  width: 100%;
  height: 100rpx;
  border-radius: var(--radius-lg) !important;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.action-btn-full::after {
  border: none;
}

.action-btn-full:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 确认评级按钮 */
.confirm-btn {
  background: linear-gradient(135deg, #3B82F6, #2563EB) !important;
  color: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(59,130,246,0.30);
}

/* 重新测评按钮 */
.retake-btn {
  background: rgba(255,255,255,0.75) !important;
  color: var(--brand-green) !important;
  border: 1rpx solid rgba(34,197,94,0.20) !important;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.retake-btn .action-btn-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}




.action-btn-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
  filter: brightness(10);
}

/* 分享按钮 */
.share-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-lg) !important;
  background: rgba(255,255,255,0.75) !important;
  color: var(--brand-blue);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(59,130,246,0.10) !important;
  line-height: 1;
  margin-bottom: 20rpx;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-sizing: border-box;
}

.share-btn:active {
  background: rgba(59,130,246,0.06) !important;
}

.share-btn-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}

/* 保存海报按钮 */
.save-poster-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-lg) !important;
  background: rgba(255,255,255,0.75) !important;
  color: var(--brand-green);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(34,197,94,0.15) !important;
  line-height: 1;
  margin-bottom: 20rpx;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-sizing: border-box;
}

.save-poster-btn:active {
  background: rgba(34,197,94,0.06) !important;
}

.save-poster-btn[disabled] {
  opacity: 0.6;
}

.save-poster-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}

/* ========== 详细报告折叠区 ========== */
.detail-section {
  margin-bottom: 24rpx;
}

.detail-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.80);
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.detail-toggle-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-toggle-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.detail-toggle-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.detail-toggle-arrow.expanded {
  transform: rotate(180deg);
}

.toggle-arrow-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.detail-content {
  margin-top: 20rpx;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== Section ========== */
.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-icon-wrap {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-icon-wrap.blue {
  background: rgba(59,130,246,0.08);
}

.section-icon-wrap.green {
  background: rgba(34,197,94,0.08);
}

.section-icon-wrap.orange {
  background: rgba(230,126,34,0.08);
}

.section-icon {
  width: 24rpx;
  height: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 内容卡片 */
.content-card {
  padding: 28rpx 36rpx;
  background: rgba(255,255,255,0.80);
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-sizing: border-box;
  overflow: hidden;
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 分项得分 */
.score-item {
  margin-bottom: 24rpx;
  padding-right: 0;
}

.score-item:last-child {
  margin-bottom: 0;
}

.score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding-right: 4rpx;
}

.score-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.score-val {
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  min-width: 60rpx;
  text-align: right;
}

.score-track {
  height: 12rpx;
  border-radius: 12rpx;
  background: rgba(59,130,246,0.05);
  overflow: hidden;
  margin-right: 0;
}

.score-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 1s ease;
}

/* 优势/待提升 */
.tag-list {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 10rpx 0;
}

.tag-list:not(:last-child) {
  border-bottom: 1rpx solid rgba(0,0,0,0.03);
  padding-bottom: 16rpx;
  margin-bottom: 4rpx;
}

.tag-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 14rpx;
}

.tag-dot.green {
  background: var(--brand-green);
}

.tag-dot.orange {
  background: #e67e22;
}

.tag-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  flex: 1;
}

/* 学习建议 */
.recommend-card {
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(27,63,145,0.04), rgba(131,186,18,0.04));
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(27,63,145,0.06);
  box-sizing: border-box;
}

.recommend-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ========== 返回首页 ========== */
/* 操作按钮同行布局 */
.action-row-inline {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

/* 半宽按钮 */
.action-btn-half {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-lg) !important;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.action-btn-half::after {
  border: none;
}

.action-btn-half:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 重新测评半宽按钮 */
.action-btn-half.retake-btn {
  background: rgba(255,255,255,0.75) !important;
  color: var(--brand-green) !important;
  border: 1rpx solid rgba(34,197,94,0.20) !important;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* 返回首页半宽按钮 */
.action-btn-half.home-btn {
  background: rgba(255,255,255,0.75) !important;
  color: var(--text-secondary) !important;
  border: 1rpx solid rgba(0,0,0,0.06) !important;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* 三按钮同行（已确认状态） */
.action-row-three {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn-third {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx !important;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  box-sizing: border-box;
  margin: 0;
  padding: 0 8rpx;
}

.action-btn-third::after {
  border: none;
}

.action-btn-third:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.action-btn-third.share-btn-mini {
  background: rgba(59,130,246,0.1) !important;
  color: #3b82f6 !important;
  border: 1rpx solid rgba(59,130,246,0.2) !important;
}

.action-btn-third.poster-btn-mini {
  background: rgba(34,197,94,0.1) !important;
  color: #22c55e !important;
  border: 1rpx solid rgba(34,197,94,0.2) !important;
}

.action-btn-third.home-btn-mini {
  background: rgba(0,0,0,0.04) !important;
  color: var(--text-secondary) !important;
  border: 1rpx solid rgba(0,0,0,0.06) !important;
}



/* ========== 确认评级相关样式 ========== */

/* 未确认提示条 */
.confirm-banner {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 243, 205, 0.90);
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.20);
  box-sizing: border-box;
}

.confirm-banner-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.confirm-banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.confirm-banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #856404;
}

.confirm-banner-desc {
  font-size: 24rpx;
  color: #856404;
  line-height: 1.6;
  opacity: 0.85;
}

/* 已确认标记 */
.confirmed-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: rgba(131,186,18,0.08);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(131,186,18,0.15);
  box-sizing: border-box;
}

.confirmed-badge-icon {
  font-size: 32rpx;
}

.confirmed-badge-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-green-dark);
}

/* ========== 逐题分析区域 ========== */
.section-icon-wrap.purple {
  background: rgba(139, 92, 246, 0.08);
}

.question-detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question-detail-item {
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.85);
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.04);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* 题号 + 得分行（可点击展开） */
.qd-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.qd-index-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.qd-index {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.qd-sublevel {
  font-size: 20rpx;
  font-weight: 500;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  background: rgba(59,130,246,0.08);
  color: var(--brand-blue);
}

.qd-passed {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.qd-passed.passed {
  background: rgba(34,197,94,0.08);
  color: #22c55e;
}

.qd-passed.failed {
  background: rgba(239,68,68,0.08);
  color: #ef4444;
}

.qd-score-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qd-score {
  font-size: 32rpx;
  font-weight: 800;
}

.qd-expand-arrow {
  width: 32rpx;
  height: 32rpx;
  transition: transform 0.3s ease;
}

.qd-expand-arrow.expanded {
  transform: rotate(180deg);
}

.qd-expand-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

/* 题目/回答 */
.qd-question,
.qd-answer {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.qd-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
  flex-shrink: 0;
  line-height: 1.8;
}

.qd-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  flex: 1;
  word-break: break-all;
}

.qd-no-answer {
  color: var(--text-placeholder);
  font-style: italic;
}

/* 录音播放按钮 - 突出显示 */
.qd-audio-btn {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  background: rgba(59,130,246,0.1);
  flex-shrink: 0;
  margin-left: 12rpx;
  border: 1rpx solid rgba(59,130,246,0.2);
}

.qd-audio-btn.playing {
  background: rgba(239,68,68,0.1);
  border-color: rgba(239,68,68,0.2);
}

.qd-audio-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.qd-audio-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-blue);
}

.qd-audio-btn.playing .qd-audio-text {
  color: #ef4444;
}

/* 用户录音回放按钮 - 独立行显示，更醒目 */
.qd-user-audio-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 14rpx 20rpx;
  background: rgba(59,130,246,0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(59,130,246,0.1);
}

.qd-user-audio-row .qd-audio-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.qd-user-audio-row .qd-audio-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.qd-user-audio-row .qd-play-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--brand-blue);
  margin-left: auto;
}

.qd-user-audio-row .qd-play-btn text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.qd-user-audio-row .qd-play-btn.playing {
  background: #ef4444;
}

.qd-user-audio-row .qd-play-btn:active {
  opacity: 0.8;
  transform: scale(0.96);
}

/* ========== 展开详情区域 ========== */
.qd-detail-expand {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(0,0,0,0.06);
  animation: fadeIn 0.3s ease;
}

.qd-detail-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

/* 四维度评分条 */
.qd-score-detail {
  margin-bottom: 20rpx;
}

.qd-score-bars {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.qd-bar-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qd-bar-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-muted);
  width: 80rpx;
  flex-shrink: 0;
  text-align: right;
}

.qd-bar-track {
  flex: 1;
  height: 16rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 8rpx;
  overflow: hidden;
}

.qd-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.qd-bar-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  width: 60rpx;
  flex-shrink: 0;
  text-align: left;
}

/* AI解析 */
.qd-ai-analysis {
  margin-bottom: 16rpx;
  padding: 20rpx;
  background: rgba(59,130,246,0.03);
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(59,130,246,0.3);
}

.qd-analysis-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 改进建议 */
.qd-suggestion-box {
  padding: 20rpx;
  background: rgba(34,197,94,0.03);
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(34,197,94,0.3);
}

.qd-suggestion-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============================
   个人介绍测评报告区块样式
   ============================ */

/* 折叠标题区 - coral图标背景 */
.section-icon-wrap.coral {
  background: linear-gradient(135deg, rgba(244,114,82,0.15), rgba(244,114,82,0.08));
}

/* 标题行信息 */
.si-toggle-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.si-level-badge {
  font-size: 22rpx;
  color: #F47252;
  font-weight: 600;
  background: rgba(244,114,82,0.08);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

/* 预估级别范围卡片 */
.si-level-card {
  background: linear-gradient(135deg, #fff7f3, #fff0eb);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(244,114,82,0.12);
}
.si-level-header {
  margin-bottom: 12rpx;
}
.si-level-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
.si-level-range {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.si-level-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #F47252;
  letter-spacing: 2rpx;
}
.si-level-names {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 录音回放卡片 */
.si-audio-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
}
.si-audio-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.si-audio-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.si-audio-duration {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: rgba(0,0,0,0.04);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.si-audio-player {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #f8f9fb, #f0f2f5);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.si-play-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}
.si-play-btn.playing {
  background: linear-gradient(135deg, #EF4444, #DC2626);
}
.si-play-icon {
  font-size: 22rpx;
  color: #fff;
  margin-left: 2rpx;
}
.si-audio-wave {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 3rpx;
  height: 40rpx;
  overflow: hidden;
}
.si-wave-bar {
  width: 4rpx;
  min-height: 6rpx;
  background: #3B82F6;
  border-radius: 2rpx;
  transition: height 0.4s ease;
  opacity: 0.5;
}
.si-wave-bar:nth-child(odd) {
  opacity: 0.7;
}
@keyframes siWaveAnim {
  0%, 100% { height: 20%; }
  50% { height: 100%; }
}
.si-play-btn.playing ~ .si-audio-wave .si-wave-bar {
  animation: siWaveAnim 0.6s ease-in-out infinite;
}
.si-play-text {
  font-size: 24rpx;
  color: #3B82F6;
  font-weight: 600;
  flex-shrink: 0;
}

/* 英文文本转写卡片 */
.si-text-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
}
.si-text-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.si-text-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.si-word-count {
  font-size: 22rpx;
  color: #3B82F6;
  font-weight: 600;
  background: rgba(59,130,246,0.08);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.si-text-content {
  background: rgba(0,0,0,0.02);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border-left: 4rpx solid rgba(59,130,246,0.3);
}
.si-transcription {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.9;
  font-style: italic;
  word-break: break-word;
}

/* 五维度能力分析卡片 */
.si-dims-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
}
.si-dims-header {
  margin-bottom: 20rpx;
}
.si-dims-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.si-dims-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.si-dim-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.si-dim-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.si-dim-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.si-dim-score {
  font-size: 26rpx;
  font-weight: 700;
}
.si-dim-bar-track {
  height: 12rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 6rpx;
  overflow: hidden;
}
.si-dim-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}
.si-dim-comment {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding-left: 4rpx;
  margin-top: 2rpx;
}

/* 综合评价卡片 */
.si-comment-card {
  background: linear-gradient(135deg, #f0f7ff, #e8f4fd);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(59,130,246,0.1);
}
.si-comment-header {
  margin-bottom: 12rpx;
}
.si-comment-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.si-comment-content {
  padding: 0;
}
.si-comment-text {
  font-size: 27rpx;
  color: var(--text-primary);
  line-height: 1.8;
}


/* ========== 英文转写高亮标注 ========== */
.si-text-badges {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}
.si-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}
.si-badge-error {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}
.si-badge-good {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

/* 高亮文本片段 */
.si-transcription-hl {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 2.2;
  word-break: break-word;
}
.si-seg {
  font-size: 28rpx;
  line-height: 2.2;
}
.si-seg-normal {
  color: var(--text-primary);
}
.si-seg-error {
  color: #EF4444;
  background: rgba(239, 68, 68, 0.08);
  border-bottom: 3rpx solid #EF4444;
  padding: 2rpx 4rpx;
  border-radius: 4rpx;
  font-weight: 500;
}
.si-seg-highlight {
  color: #059669;
  background: rgba(16, 185, 129, 0.1);
  border-bottom: 3rpx solid #10B981;
  padding: 2rpx 4rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

/* 高亮详情气泡遮罩 */
.si-hl-bubble {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  animation: hlBubbleFadeIn 0.25s ease-out;
}
@keyframes hlBubbleFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.si-hl-bubble-inner {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: hlBubbleSlideUp 0.3s ease-out;
}
@keyframes hlBubbleSlideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.si-hl-bubble-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.si-hl-bubble-word {
  font-size: 34rpx;
  font-weight: 700;
  font-family: 'Georgia', serif;
}
.si-hl-word-error {
  color: #EF4444;
}
.si-hl-word-highlight {
  color: #059669;
}
.si-hl-bubble-type {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 500;
}
.si-hl-type-error {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}
.si-hl-type-highlight {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

/* 建议改为 */
.si-hl-suggestion {
  background: rgba(59, 130, 246, 0.06);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.si-hl-suggestion-label {
  font-size: 24rpx;
  color: #6B7280;
  white-space: nowrap;
}
.si-hl-suggestion-text {
  font-size: 30rpx;
  color: #3B82F6;
  font-weight: 600;
  font-family: 'Georgia', serif;
}

/* 原因说明 */
.si-hl-reason {
  margin-bottom: 20rpx;
}
.si-hl-reason-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.7;
}

/* 关闭按钮 */
.si-hl-bubble-close {
  display: flex;
  justify-content: center;
  padding: 14rpx 0 4rpx;
}
.si-hl-bubble-close text {
  font-size: 26rpx;
  color: #3B82F6;
  font-weight: 500;
  padding: 8rpx 40rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  border-radius: 32rpx;
  background: rgba(59, 130, 246, 0.04);
}

/* 图例 */
.si-text-legend {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.si-legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.si-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.si-legend-error {
  background: #EF4444;
}
.si-legend-good {
  background: #10B981;
}
.si-legend-label {
  font-size: 22rpx;
  color: #6B7280;
}
.si-legend-tip {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-left: auto;
}

/* ========== 报告Tab切换栏 ========== */
.report-tabs {
  margin-bottom: 24rpx;
}

.report-tab-bar {
  display: flex;
  gap: 0;
  background: #f1f5f9;
  border-radius: 20rpx;
  padding: 6rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.06);
}

.report-tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  position: relative;
}

.report-tab-item.active {
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08), 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
}

.report-tab-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #94a3b8;
  transition: color 0.3s ease;
}

.report-tab-item.active .report-tab-text {
  color: #1e293b;
  font-weight: 600;
}

/* Tab内容区域 */
.report-tab-content {
  animation: tabFadeIn 0.3s ease;
}

.report-tab-content .detail-section {
  margin-bottom: 0;
}

@keyframes tabFadeIn {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 逐题分析Tab标题 */
.report-tab-section-header {
  padding: 20rpx 24rpx 12rpx;
}

.report-tab-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
}
