/* 途正英语 - 测评说明页样式（小程序原生适配版） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 主体内容 - scroll-view */
.body {
  height: 100vh;
  padding: 24rpx 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
}

/* AI老师卡片 */
.teacher-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(27,63,145,0.10);
  flex-shrink: 0;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--brand-blue);
  margin-bottom: 4rpx;
}

.teacher-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

/* 测评原理简介 */
.intro-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.intro-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--brand-blue);
  margin-bottom: 10rpx;
}

.intro-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* Section */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* Flow Steps - 时间线样式 */
.flow-steps {
  display: flex;
  flex-direction: column;
}

.flow-step {
  display: flex;
  gap: 20rpx;
}

/* 左侧时间线 */
.flow-timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 24rpx;
  flex-shrink: 0;
  padding-top: 6rpx;
}

.flow-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.8);
}

.flow-line {
  flex: 1;
  width: 0;
  border-left: 3rpx solid rgba(27,63,145,0.15);
  min-height: 20rpx;
}

/* 右侧内容 */
.flow-content {
  flex: 1;
  padding-bottom: 20rpx;
}

.flow-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.flow-icon-wrap {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.flow-icon {
  width: 24rpx;
  height: 24rpx;
}

.flow-title {
  font-size: 26rpx;
  font-weight: 700;
}

.flow-loop-badge {
  background: rgba(230,126,34,0.12);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}

.flow-loop-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #e67e22;
}

.flow-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
  padding-left: 56rpx;
}

/* 循环提示卡片 */
.loop-hint-card {
  margin-top: 12rpx;
  margin-left: 56rpx;
  padding: 16rpx 20rpx;
  background: rgba(230,126,34,0.06);
  border-radius: 12rpx;
  border-left: 4rpx solid #e67e22;
}

.loop-hint-text {
  font-size: 22rpx;
  color: #b35c10;
  line-height: 1.5;
}

/* Tips */
.tips-card {
  padding: 24rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* Permission */
.permission-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-card);
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 2rpx solid rgba(27,63,145,0.12);
}

.permission-card.permission-granted {
  background: rgba(131,186,18,0.06);
  border-color: rgba(131,186,18,0.30);
}

.permission-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.permission-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(27,63,145,0.08);
  flex-shrink: 0;
}

.permission-icon-wrap.icon-granted {
  background: rgba(131,186,18,0.15);
}

.permission-icon {
  width: 36rpx;
  height: 36rpx;
}

.permission-info {
  flex: 1;
}

.permission-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.permission-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 2rpx;
}

.permission-status {
  margin-top: 16rpx;
  text-align: center;
}

.status-granted {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-green);
}

.permission-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1B3F91, #2B5BA0) !important;
  color: #ffffff !important;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-full) !important;
  padding: 12rpx 48rpx !important;
  line-height: 1.4;
  border: none;
}

.permission-btn::after {
  border: none;
}

/* Bottom */
.bottom-area {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.bottom-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 16rpx;
}
