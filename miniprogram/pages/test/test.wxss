  transition: width 0.15s ease;
  min-width: 0;
}

.analysis-step-fill.completed {
  background: var(--brand-green, #83BA12);
}

/* ========== 简短回答提示弹窗 ========== */
.brief-hint-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 0 48rpx;
}

.brief-hint-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 56rpx 40rpx 40rpx;
  width: 100%;
  max-width: 580rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.brief-hint-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.brief-hint-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.brief-hint-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
  padding: 0 8rpx;
}

.brief-hint-actions {
  display: flex;
  gap: 20rpx;
}

.brief-hint-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.brief-hint-btn.retry {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #fff;
}

.brief-hint-btn.submit {
  background: #f0f0f0;
  color: #666;
}

/* ============ 录音确认阶段（重听/重录/提交） ============ */
.confirm-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.confirm-btn-submit {
  width: 100%;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-light));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(27,63,145,0.25);
}

.confirm-btn-submit:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(27,63,145,0.35);
}

.confirm-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.confirm-secondary-row {
  display: flex;
  gap: 20rpx;
}

.confirm-btn-secondary {
  flex: 1;
  height: 88rpx;
  border-radius: 14rpx;
  background: rgba(27,63,145,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.15s ease;
}

.confirm-btn-secondary:active {
  background: rgba(27,63,145,0.15);
  transform: scale(0.97);
}

.confirm-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.7;
}

.confirm-secondary-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-blue);
}
