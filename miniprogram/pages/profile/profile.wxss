/* 途正英语 - 用户资料完善页样式 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFFFFF 40%);
}

/* ============ 导航栏 ============ */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 248, 240, 0.95);
  backdrop-filter: blur(20px);
}

.nav-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 1rpx;
}

/* ============ 顶部提示区 ============ */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx 32rpx;
}

.header-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #8c8c9a;
  text-align: center;
  line-height: 1.5;
}

/* ============ 表单区域 ============ */
.form-section {
  padding: 0 32rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.address-icon {
  background: linear-gradient(135deg, #FFF0E6 0%, #FFE0CC 100%);
}

.payment-icon {
  background: linear-gradient(135deg, #E6F0FF 0%, #CCE0FF 100%);
}

.card-icon .iconfont {
  font-size: 32rpx;
}

.card-title-group {
  flex: 1;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.3;
}

.card-subtitle {
  font-size: 24rpx;
  color: #8c8c9a;
  margin-top: 2rpx;
}

.required-badge {
  font-size: 22rpx;
  color: #FF6B35;
  background: #FFF0E6;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

/* ============ 表单字段 ============ */
.form-fields {
  background: #FAFAFA;
  border-radius: 16rpx;
  overflow: hidden;
}

.field-row {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.field-row-last {
  border-bottom: none;
}

.field-label {
  font-size: 28rpx;
  color: #4a4a5a;
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
  height: 48rpx;
  line-height: 48rpx;
}

.field-input::placeholder {
  color: #C0C0C8;
}

.field-picker {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-picker.placeholder {
  color: #C0C0C8;
}

.picker-arrow {
  font-size: 24rpx;
  color: #C0C0C8;
  margin-left: 8rpx;
}

.hidden-picker {
  position: absolute;
  width: 0;
  height: 0;
  overflow: hidden;
  opacity: 0;
}

/* ============ 上传区域 ============ */
.upload-area {
  border: 2rpx dashed #D8D8E0;
  border-radius: 16rpx;
  overflow: hidden;
  transition: border-color 0.2s;
}

.upload-area:active {
  border-color: #FF6B35;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56rpx 0;
}

.upload-icon-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF0E6 0%, #FFE0CC 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.upload-plus {
  font-size: 48rpx;
  color: #FF6B35;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #4a4a5a;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #B0B0B8;
}

.upload-preview-wrap {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-preview {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.upload-replace-btn {
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border: 1rpx solid #FF6B35;
  border-radius: 24rpx;
}

/* ============ 提交按钮 ============ */
.submit-section {
  padding: 40rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5E 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
  transition: all 0.2s;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.2);
}

.submit-btn.disabled {
  background: linear-gradient(135deg, #D0D0D8 0%, #E0E0E8 100%);
  color: #A0A0A8;
  box-shadow: none;
}

.loading-dot {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.submit-hint {
  font-size: 24rpx;
  color: #B0B0B8;
  margin-top: 16rpx;
}
