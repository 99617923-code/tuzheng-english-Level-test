<!--
  途正英语AI分级测评 - 测评主页面（v4.0 自我介绍预估 + 分析进度条）
  核心交互：
  - AI智能模式：自我介绍录音 → AI预估水平 → 从预估起点开始做题
  - 标准模式：自动播放外教语音 → 点击录音回答 → AI评分 → 自适应升级 → 下一题/出结果
  - 分析进度条：每题提交后展示AI分析各步骤的实时进度
-->
<view class="page">
  <!-- 自定义导航栏（只保留返回按钮） -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="handleQuit">
        <image class="nav-back-icon" src="/assets/icons/x.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-wrap" style="top: {{navBarHeight}}px;">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
  </view>

  <!-- 主内容区 -->
  <view class="main-area" style="padding-top: {{navBarHeight + 20}}px;">
    <!-- 级别 & 题号信息条 + 计时器（自我介绍阶段隐藏） -->
    <view wx:if="{{phase !== 'selfIntro'}}" class="level-info-bar">
      <view class="level-info-left">
        <text class="level-info-level">途正口语{{currentMajorLevel}}级</text>
        <text class="level-info-progress">{{questionCountDisplay}}</text>
        <!-- v4.0 AI智能定级模式标签 -->
        <text wx:if="{{modeLabel}}" class="mode-label mode-label-analyzing">{{modeLabel}}</text>
      </view>
      <view class="level-info-timer">
        <image class="timer-icon" src="/assets/icons/clock.svg" mode="aspectFit" />
        <text class="timer-text">{{timerDisplay}}</text>
      </view>
    </view>

    <!-- ========== 自我介绍阶段（v4.0 新增） ========== -->
    <view wx:if="{{phase === 'selfIntro' || selfIntroUploading || showEstimateResult}}" class="self-intro-section">
      <!-- AI头像 + 状态 -->
      <view class="ai-header">
        <view class="ai-avatar-wrap">
          <image class="ai-avatar" src="{{aiAvatarUrl}}" mode="aspectFill" />
        </view>
        <view class="ai-info">
          <text class="ai-name">{{teacherName}}</text>
          <text class="ai-status">{{aiStatusText}}</text>
        </view>
      </view>

      <!-- 自我介绍引导卡片 -->
      <view wx:if="{{!selfIntroUploading && !showEstimateResult}}" class="intro-guide-card glass-card-strong animate-fade-in">
        <view class="intro-guide-header">
          <text class="intro-guide-icon">🎙️</text>
          <text class="intro-guide-title">{{selfIntroGuide.title || '请用英语做一段自我介绍'}}</text>
        </view>
        <text class="intro-guide-desc">{{selfIntroGuide.description || '请用英语介绍你的名字、从哪里来、学业情况、职业情况、学英语的动力来源和目标。'}}</text>
        <view class="intro-guide-tips">
          <view wx:for="{{selfIntroGuide.tips}}" wx:key="index" class="intro-tip-item">
            <text class="intro-tip-dot">•</text>
            <text class="intro-tip-text">{{item}}</text>
          </view>
        </view>
        <view class="intro-guide-duration">
          <text class="intro-duration-text">建议时长：{{selfIntroGuide.duration || '30秒~2分钟'}}</text>
        </view>
      </view>

      <!-- 自我介绍录音中状态 -->
      <view wx:if="{{selfIntroRecording}}" class="intro-recording-card glass-card-strong animate-fade-in">
        <view class="intro-recording-header">
          <view class="intro-recording-dot"></view>
          <text class="intro-recording-label">正在录音</text>
          <text class="intro-recording-time">{{selfIntroRecordTimeDisplay}}</text>
        </view>
        <view class="intro-recording-waves">
          <view wx:for="{{recordWaveBars}}" wx:key="index" class="intro-wave-bar" style="height: {{item}}rpx;"></view>
        </view>
        <text class="intro-recording-hint">松开按钮结束录音</text>
      </view>

      <!-- 正在分析中状态 -->
      <view wx:if="{{selfIntroUploading}}" class="intro-analyzing-card glass-card-strong animate-fade-in">
        <view class="intro-analyzing-content">
          <view class="spinner"></view>
          <text class="intro-analyzing-text">AI正在分析你的英语水平...</text>
          <text class="intro-analyzing-hint">这可能需要几秒钟</text>
        </view>
      </view>

      <!-- 预估结果展示 -->
      <view wx:if="{{showEstimateResult}}" class="intro-result-card glass-card-strong animate-fade-in">
        <view class="intro-result-icon">✨</view>
        <text class="intro-result-text">{{estimateResultText}}</text>
        <text class="intro-result-hint">即将开始测评...</text>
        <view class="intro-result-dots">
          <view class="listening-dot"></view>
          <view class="listening-dot"></view>
          <view class="listening-dot"></view>
        </view>
      </view>
    </view>

    <!-- ========== 正常做题阶段 ========== -->
    <view wx:elif="{{phase !== 'selfIntro'}}" class="question-card glass-card-strong animate-fade-in">
      <!-- AI头像 + 状态 -->
      <view class="ai-header">
        <view class="ai-avatar-wrap">
          <image class="ai-avatar" src="{{aiAvatarUrl}}" mode="aspectFill" />
          <view wx:if="{{aiSpeaking}}" class="ai-speaking-dot"></view>
        </view>
        <view class="ai-info">
          <text class="ai-name">{{teacherName}}</text>
          <text class="ai-status">{{aiStatusText}}</text>
        </view>
      </view>

      <!-- AI语音播放条（外教真人录音） - 点击可重播 -->
      <view wx:if="{{phase !== 'guide' && phase !== 'loading' && currentQuestion}}" class="audio-bar" bindtap="playAudio">
        <view class="audio-play-btn">
          <image wx:if="{{!audioPlaying}}" class="audio-play-icon" src="/assets/icons/play.svg" mode="aspectFit" />
          <image wx:else class="audio-play-icon" src="/assets/icons/pause.svg" mode="aspectFit" />
        </view>
        <view class="audio-waves">
          <view wx:for="{{audioWaves}}" wx:key="index" class="audio-wave-bar {{audioPlaying ? 'playing' : ''}}" style="height: {{item}}rpx; animation-delay: {{index * 0.05}}s;"></view>
        </view>
      </view>

      <!-- 音频失败时显示题目文字（兆底） -->
      <view wx:if="{{showQuestionText}}" class="question-text-fallback">
        <text class="question-text-label">📝 请阅读题目并用英语回答：</text>
        <text class="question-text-content">{{questionTextDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- v4.0 分析进度条浮层 -->
  <view wx:if="{{showAnalysisProgress}}" class="analysis-progress-overlay">
    <view class="analysis-progress-card animate-fade-in">
      <text class="analysis-progress-title">AI 正在分析你的回答</text>
      <view class="analysis-steps-list">
        <view wx:for="{{analysisSteps}}" wx:key="index" class="analysis-step-item {{index <= analysisCurrentStep ? 'active' : ''}} {{item.percentage >= 100 ? 'completed' : ''}}">
          <view class="analysis-step-info">
            <text class="analysis-step-name">{{item.name}}</text>
            <text class="analysis-step-pct">{{item.pctDisplay}}%</text>
          </view>
          <view class="analysis-step-bar">
            <view class="analysis-step-fill {{item.percentage >= 100 ? 'completed' : ''}}" style="width: {{item.percentage}}%;"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 音量提醒浮层 -->
  <view wx:if="{{showVolumeReminder}}" class="volume-reminder-overlay" bindtap="dismissVolumeReminder">
    <view class="volume-reminder-card animate-fade-in" catchtap="">
      <view class="volume-reminder-icon-wrap">
        <text class="volume-reminder-icon">🔊</text>
      </view>
      <text class="volume-reminder-title">请确保手机未静音</text>
      <text class="volume-reminder-desc">测评过程中需要听清{{teacherName}}的英语提问，请关闭静音开关并调高音量。</text>
      <view class="volume-reminder-btn" bindtap="dismissVolumeReminder">
        <text>我知道了</text>
      </view>
    </view>
  </view>

  <!-- 简短回答提示弹窗 -->
  <view wx:if="{{showBriefHint}}" class="brief-hint-overlay">
    <view class="brief-hint-card animate-fade-in">
      <view class="brief-hint-icon">💡</view>
      <view class="brief-hint-title">尝试说得更多一些</view>
      <view class="brief-hint-desc">回答得越详细，AI能更准确地评估你的英语水平。试试用完整的句子来回答吧！</view>
      <view class="brief-hint-actions">
        <view class="brief-hint-btn retry" bindtap="handleBriefHintRetry">重新回答</view>
        <view class="brief-hint-btn submit" bindtap="handleBriefHintSubmit">继续提交</view>
      </view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="bottom-bar">
    <!-- v4.0 自我介绍阶段操作区 -->
    <view wx:if="{{phase === 'selfIntro' && !selfIntroUploading && !showEstimateResult}}" class="action-area">
      <!-- 按住录制自我介绍按钮 -->
      <view
        wx:if="{{!selfIntroRecording}}"
        class="wechat-record-btn intro-record-btn"
        bindtouchstart="onSelfIntroTouchStart"
        bindtouchend="onSelfIntroTouchEnd"
        bindtouchcancel="onSelfIntroTouchEnd"
      >
        <text class="wechat-record-text intro-record-text">按住开始录制自我介绍</text>
      </view>
      <view
        wx:else
        class="wechat-record-btn recording intro-record-btn"
        bindtouchend="onSelfIntroTouchEnd"
        bindtouchcancel="onSelfIntroTouchEnd"
      >
        <text class="wechat-record-text">松开 结束录音</text>
      </view>
      <view class="skip-row">
        <button class="skip-btn intro-skip-btn" bindtap="handleSkipIntro">跳过自我介绍，从头开始逐级测试</button>
      </view>
    </view>

    <!-- 自我介绍分析中 / 预估结果展示中 - 不可操作 -->
    <view wx:elif="{{selfIntroUploading || showEstimateResult}}" class="action-area">
      <view class="evaluating-wrap">
        <view wx:if="{{selfIntroUploading}}" class="spinner"></view>
        <text class="evaluating-text">{{selfIntroUploading ? 'AI正在分析中...' : '即将开始测评...'}}</text>
      </view>
    </view>

    <!-- 状态：准备回答 / 录音中（含自动播放后进入） -->
    <view wx:elif="{{phase === 'answering'}}" class="action-area">
      <!-- 微信风格长条按住说话按钮 -->
      <view
        class="wechat-record-btn {{isRecording ? 'recording' : ''}}"
        bindtouchstart="onRecordTouchStart"
        bindtouchend="onRecordTouchEnd"
        bindtouchcancel="onRecordTouchEnd"
      >
        <text class="wechat-record-text">按住 说话</text>
      </view>
      <view class="skip-row">
        <button class="skip-btn" bindtap="handleSkip">跳过此题</button>
      </view>
    </view>

    <!-- 状态：正在播放AI语音（自动播放中，不可操作） -->
    <view wx:elif="{{phase === 'listening'}}" class="action-area">
      <view class="listening-hint-wrap">
        <view class="listening-dots">
          <view class="listening-dot"></view>
          <view class="listening-dot"></view>
          <view class="listening-dot"></view>
        </view>
        <text class="listening-hint-text">正在播放题目，请仔细听...</text>
      </view>
    </view>

    <!-- 状态：评估中 -->
    <view wx:elif="{{phase === 'evaluating'}}" class="action-area">
      <view class="evaluating-wrap">
        <view class="spinner"></view>
        <text class="evaluating-text">正在评估你的回答...</text>
      </view>
    </view>

    <!-- 状态：加载中 -->
    <view wx:elif="{{phase === 'loading'}}" class="action-area">
      <view class="evaluating-wrap">
        <view class="spinner"></view>
        <text class="evaluating-text">正在准备测评...</text>
      </view>
    </view>

    <!-- 状态：外教引导 -->
    <view wx:elif="{{phase === 'guide'}}" class="action-area guide-area">
      <!-- 引导气泡内容 -->
      <view class="guide-bubble-wrap">
        <!-- Step 1: 欢迎 -->
        <view wx:if="{{guideStep === 1}}" class="guide-bubble animate-fade-in">
          <text class="guide-emoji">👋</text>
          <text class="guide-title">你好！我是{{teacherTitle}}</text>
          <text class="guide-desc">接下来我会用英语和你对话，测出你的真实英语水平。很简单，跟着我的引导就好！</text>
          <view class="guide-btns">
            <button class="guide-btn-skip" bindtap="handleGuideSkip">跳过，直接开始</button>
            <button class="guide-btn-next" bindtap="handleGuideNext">了解一下</button>
          </view>
        </view>

        <!-- Step 2: 流程说明 -->
        <view wx:elif="{{guideStep === 2}}" class="guide-bubble animate-fade-in">
          <text class="guide-title">测评流程很简单</text>
          <view class="guide-steps">
            <view class="guide-step-item">
              <text class="guide-step-num">1</text>
              <text class="guide-step-text">听{{teacherName}}的英语提问</text>
            </view>
            <view class="guide-step-item">
              <text class="guide-step-num">2</text>
              <text class="guide-step-text">点击麦克风，用英语回答</text>
            </view>
            <view class="guide-step-item">
              <text class="guide-step-num">3</text>
              <text class="guide-step-text">答对了，AI出更难的题</text>
            </view>
            <view class="guide-step-item">
              <text class="guide-step-num">4</text>
              <text class="guide-step-text">直到测出你的真实水平</text>
            </view>
          </view>
          <view class="guide-btns">
            <button class="guide-btn-skip" bindtap="handleGuideSkip">跳过</button>
            <button class="guide-btn-next" bindtap="handleGuideNext">明白了</button>
          </view>
        </view>

        <!-- Step 3: 准备开始 -->
        <view wx:elif="{{guideStep === 3}}" class="guide-bubble animate-fade-in">
          <text class="guide-emoji">🌟</text>
          <text class="guide-title">准备好了吗？</text>
          <text class="guide-desc">请在安静的环境中进行，说话时靠近手机麦克风。不会的可以说 "I don't know" 或跳过。</text>
          <view class="guide-btns">
            <button class="guide-btn-start" bindtap="handleGuideStart">开始测评 →</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 录音中全屏遮罩（微信风格） - 放在页面最外层确保覆盖全屏 -->
  <view wx:if="{{isRecording}}" class="recording-overlay" catchtouchmove="preventTouchMove" bindtouchend="onRecordTouchEnd" bindtouchcancel="onRecordTouchEnd" bindtap="onOverlayTap">
    <view class="recording-overlay-bg"></view>
    <view class="recording-indicator">
      <view class="recording-wave-box">
        <view class="recording-wave-bar" wx:for="{{recordWaveBars}}" wx:key="index" style="height: {{item}}rpx;"></view>
      </view>
    </view>
    <view class="recording-bottom">
      <text class="recording-countdown" wx:if="{{recordCountdown > 0}}">{{recordCountdown}}s</text>
      <text class="recording-send-hint">松开 发送</text>
    </view>
  </view>
</view>
