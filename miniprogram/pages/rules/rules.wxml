<!--
  途正英语AI分级测评 - 测评说明页
  优化：授权+开始按钮置顶，说明内容折叠收起
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="goBack">
        <image class="nav-back-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
      </view>
      <text class="nav-title-center">测评说明</text>
      <view class="nav-right-placeholder"></view>
    </view>
  </view>

  <!-- 主体内容 -->
  <scroll-view scroll-y class="body" style="padding-top: {{navBarHeight}}px;">

    <!-- 顶部核心区域：授权状态 + 开始按钮 -->
    <view class="hero-section">
      <!-- 外教简介 -->
      <view class="hero-teacher">
        <image class="hero-avatar" src="{{aiAvatarUrl}}" mode="aspectFill" />
        <view class="hero-teacher-info">
          <text class="hero-teacher-name">{{teacherName}}</text>
          <text class="hero-teacher-desc">和你进行英语对话，精准评估你的水平</text>
        </view>
      </view>

      <!-- 授权状态指示 -->
      <view class="auth-status-bar {{recordPermission === 'authorized' ? 'auth-granted' : 'auth-pending'}}" bindtap="requestPermission">
        <view class="auth-icon-wrap">
          <image class="auth-icon" src="/assets/icons/{{recordPermission === 'authorized' ? 'mic-green' : 'mic-orange'}}.svg" mode="aspectFit" />
        </view>
        <view class="auth-text-wrap">
          <text class="auth-label" wx:if="{{recordPermission === 'authorized'}}">麦克风已授权</text>
          <text class="auth-label" wx:elif="{{recordPermission === 'denied'}}">麦克风未授权</text>
          <text class="auth-label" wx:else>麦克风授权中...</text>
          <text class="auth-hint" wx:if="{{recordPermission === 'authorized'}}">录音权限就绪，可以开始测评</text>
          <text class="auth-hint" wx:elif="{{recordPermission === 'denied'}}">点击此处前往设置开启</text>
          <text class="auth-hint" wx:else>测评需要录音权限</text>
        </view>
        <view class="auth-badge" wx:if="{{recordPermission === 'authorized'}}">
          <text class="auth-badge-text">✓</text>
        </view>
        <view class="auth-badge auth-badge-warn" wx:elif="{{recordPermission === 'denied'}}">
          <text class="auth-badge-text">!</text>
        </view>
      </view>

      <!-- 开始测评按钮 -->
      <button class="btn-start {{recordPermission !== 'authorized' ? 'btn-start-disabled' : ''}}" bindtap="handleStartTest">
        <text class="btn-start-text">{{recordPermission === 'authorized' ? '开始测评' : '请先授权麦克风'}}</text>
      </button>
      <text class="hero-hint">测评约需3-5分钟，从基础开始逐步升级</text>
    </view>

    <!-- 分隔线 -->
    <view class="divider"></view>

    <!-- 折叠面板：测评流程 -->
    <view class="collapse-section">
      <view class="collapse-header" bindtap="toggleSection" data-section="flow">
        <view class="collapse-title-wrap">
          <text class="collapse-title">测评流程</text>
          <text class="collapse-subtitle">了解自适应分级测评如何运作</text>
        </view>
        <view class="collapse-arrow {{expandedSections.flow ? 'arrow-expanded' : ''}}">
          <image class="collapse-arrow-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="collapse-body {{expandedSections.flow ? 'collapse-expanded' : ''}}">
        <view class="collapse-inner">
          <!-- 测评原理 -->
          <view class="principle-card">
            <text class="principle-text">系统从基础题目开始，每答对一题自动升级到更高难度。题目会越来越难，直到找到你的真实水平为止。</text>
          </view>

          <!-- 流程步骤 -->
          <view class="flow-steps">
            <view class="flow-step" wx:for="{{steps}}" wx:key="index">
              <view class="flow-timeline">
                <view class="flow-dot" style="background: {{item.color}};"></view>
                <view class="flow-line" wx:if="{{index < steps.length - 1}}" style="{{item.isLoop ? 'border-left-style: dashed; border-left-color: #e67e22;' : ''}}"></view>
              </view>
              <view class="flow-content">
                <view class="flow-header">
                  <view class="flow-icon-wrap" style="background: {{item.bgColor}};">
                    <image class="flow-icon" src="/assets/icons/{{item.icon}}.svg" mode="aspectFit" />
                  </view>
                  <text class="flow-title" style="color: {{item.color}};">{{item.title}}</text>
                  <view class="flow-loop-badge" wx:if="{{item.isLoop}}">
                    <text class="flow-loop-text">循环</text>
                  </view>
                </view>
                <text class="flow-desc">{{item.desc}}</text>
                <view class="loop-hint-card" wx:if="{{item.isLoop}}">
                  <text class="loop-hint-text">步骤①~④会反复进行，直到测出你的真实水平</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 折叠面板：注意事项 -->
    <view class="collapse-section">
      <view class="collapse-header" bindtap="toggleSection" data-section="tips">
        <view class="collapse-title-wrap">
          <text class="collapse-title">注意事项</text>
          <text class="collapse-subtitle">获得更准确测评结果的小贴士</text>
        </view>
        <view class="collapse-arrow {{expandedSections.tips ? 'arrow-expanded' : ''}}">
          <image class="collapse-arrow-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="collapse-body {{expandedSections.tips ? 'collapse-expanded' : ''}}">
        <view class="collapse-inner">
          <view class="tips-list">
            <view class="tip-row" wx:for="{{tips}}" wx:key="index">
              <text class="tip-emoji">{{item.icon}}</text>
              <text class="tip-text">{{item.text}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部留白 -->
    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>
