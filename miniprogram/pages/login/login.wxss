/* 途正英语 - 登录页样式（小程序原生适配版） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 导航栏样式使用全局 custom-nav */

/* 主内容 */
.content {
  padding: 0 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

/* 品牌区域 */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 48rpx;
}

.brand-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 8rpx 32rpx rgba(27,63,145,0.15);
  margin-bottom: 24rpx;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--brand-blue);
  margin-bottom: 8rpx;
}

.brand-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 登录区域 */
.login-area {
  margin-top: 32rpx;
}

/* 微信快捷登录 */
.wx-login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-login-btn {
  width: 100%;
  height: 104rpx;
  border-radius: var(--radius-lg);
  background: #07C160 !important;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(7,193,96,0.30);
  line-height: 1;
  padding: 0;
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn:active {
  background: #06ad56 !important;
}

.wx-icon {
  width: 40rpx;
  height: 40rpx;
}

.wx-login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.wx-login-hint {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 16rpx;
}

/* 分割线 */
.divider-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: rgba(27,63,145,0.08);
}

.divider-text {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

/* 短信登录切换 */
.sms-login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sms-toggle {
  padding: 16rpx 32rpx;
}

.sms-toggle-text {
  font-size: 28rpx;
  color: var(--brand-blue);
  font-weight: 500;
}

/* 短信登录表单 */
.sms-form {
  width: 100%;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 96rpx;
  padding: 0 28rpx;
  background: rgba(255,255,255,0.70);
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(27,63,145,0.06);
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.4;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.code-row {
  display: flex;
  gap: 16rpx;
}

.code-input-wrap {
  flex: 1;
}

.send-code-btn {
  flex-shrink: 0;
  height: 96rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-md);
  background: rgba(27,63,145,0.06) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.send-code-btn::after {
  border: none;
}

.send-code-btn.disabled {
  opacity: 0.5;
}

.code-btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--brand-blue);
  white-space: nowrap;
}

.sms-login-btn {
  width: 100%;
  height: 104rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-light)) !important;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(27,63,145,0.25);
  line-height: 1;
  margin-top: 8rpx;
}

.sms-login-btn::after {
  border: none;
}

.sms-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 48rpx;
  gap: 0;
}

.agreement-text {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.agreement-link {
  font-size: 22rpx;
  color: var(--brand-blue);
}
