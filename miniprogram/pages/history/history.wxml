<!--
  途正英语AI分级测评 - 历史记录页
  优化排版：左侧序号+右侧信息，日期完整显示，状态更醒目
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="goBack">
        <image class="nav-back-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
      </view>
      <text class="nav-title-center">测评记录</text>
      <view class="nav-right-placeholder"></view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view
    scroll-y
    class="scroll-area"
    style="top: {{navBarHeight}}px;"
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
  >
    <!-- 加载中 -->
    <view wx:if="{{loading && list.length === 0}}" class="empty-state">
      <view class="spinner"></view>
      <text class="empty-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{!loading && list.length === 0}}" class="empty-state">
      <view class="empty-icon-wrap">
        <image class="empty-icon" src="/assets/icons/history.svg" mode="aspectFit" />
      </view>
      <text class="empty-title">暂无测评记录</text>
      <text class="empty-desc">完成一次测评后，记录将显示在这里</text>
      <button class="empty-btn" bindtap="goTest">开始测评</button>
    </view>

    <!-- 统计摘要 -->
    <view wx:if="{{list.length > 0}}" class="summary-bar">
      <view class="summary-item">
        <text class="summary-value">{{list.length}}</text>
        <text class="summary-label">总测评</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-value">{{completedCount}}</text>
        <text class="summary-label">已完成</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-value {{bestLevel ? '' : 'muted'}}">{{bestLevel || '-'}}</text>
        <text class="summary-label">最高等级</text>
      </view>
    </view>

    <!-- 记录列表 -->
    <view wx:if="{{list.length > 0}}" class="list">
      <view
        class="record-card glass-card animate-fade-in"
        wx:for="{{list}}"
        wx:key="sessionId"
        bindtap="viewDetail"
        data-session-id="{{item.sessionId}}"
        style="animation-delay: {{index * 0.05}}s;"
      >
        <!-- 左侧：序号圆圈 + 状态色条 -->
        <view class="card-left">
          <view class="index-circle {{item.status === 'completed' ? 'completed' : ''}}">
            <text class="index-num">{{index + 1}}</text>
          </view>
          <view class="status-line {{item.status === 'completed' ? 'completed' : ''}}"></view>
        </view>

        <!-- 右侧：主信息 -->
        <view class="card-right">
          <!-- 第一行：等级 + 状态 -->
          <view class="card-row-top">
            <view wx:if="{{item.status === 'completed'}}" class="level-tag" style="background: {{item.levelColor}};">
              <text class="level-tag-text">{{item.levelName}}</text>
            </view>
            <view wx:else class="level-tag incomplete">
              <text class="level-tag-text">未完成</text>
            </view>
            <view class="status-badge {{item.status === 'completed' ? 'done' : 'pending'}}">
              <view class="status-dot"></view>
              <text class="status-text">{{item.statusText}}</text>
            </view>
          </view>

          <!-- 第二行：等级描述 -->
          <text wx:if="{{item.levelLabel}}" class="level-desc">{{item.levelLabel}}</text>

          <!-- 第三行：统计数据 -->
          <view class="card-stats">
            <view class="stat-chip">
              <image class="stat-icon" src="/assets/icons/mic.svg" mode="aspectFit" />
              <text class="stat-text">{{item.questionCount || 0}} 题</text>
            </view>
            <view class="stat-chip">
              <image class="stat-icon" src="/assets/icons/clock.svg" mode="aspectFit" />
              <text class="stat-text">{{item.durationText || '-'}}</text>
            </view>
          </view>

          <!-- 第四行：日期 + 箭头 -->
          <view class="card-row-bottom">
            <text class="card-date">{{item.completedAtFormatted}}</text>
            <image class="arrow-icon" src="/assets/icons/chevron-right.svg" mode="aspectFit" />
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loadingMore}}" class="loading-more">
        <view class="spinner-small"></view>
        <text class="loading-more-text">加载中...</text>
      </view>

      <view wx:elif="{{noMore}}" class="no-more">
        <text class="no-more-text">— 没有更多记录了 —</text>
      </view>
    </view>
  </scroll-view>
</view>
