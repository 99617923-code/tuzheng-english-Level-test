/* 途正英语 - 历史记录页样式（全新设计） */
.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 滚动区 */
.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 32rpx;
}

/* ========== 统计头部 ========== */
.stats-header {
  position: relative;
  margin: 24rpx 0 32rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.stats-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1B3F91 0%, #2B5BA0 50%, #3a6db5 100%);
  border-radius: var(--radius-lg);
}

.stats-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-number {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.1;
}

.stat-number.no-data {
  opacity: 0.5;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.15);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid rgba(27,63,145,0.15);
  border-top-color: var(--brand-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.empty-illustration {
  margin-bottom: 40rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(27,63,145,0.06), rgba(131,186,18,0.06));
  border: 2rpx solid rgba(27,63,145,0.08);
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.4;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 48rpx;
}

.empty-btn {
  background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-light)) !important;
  color: #ffffff !important;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-full) !important;
  padding: 24rpx 72rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(27,63,145,0.25);
  line-height: 1.4;
}

/* ========== 记录列表 ========== */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: rgba(255,255,255,0.80);
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 4rpx 16rpx rgba(27,63,145,0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.record-item:active {
  transform: scale(0.98);
  transition: transform 0.15s ease;
  background: rgba(255,255,255,0.95);
}

/* 左侧等级徽章 */
.item-left {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.level-badge-sm {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-sm);
  min-width: 96rpx;
}

.level-badge-sm.incomplete {
  background: rgba(138,149,165,0.10);
}

.level-badge-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
}

.level-badge-sm.incomplete .level-badge-text {
  color: #8a95a5;
}

/* 中间信息 */
.item-center {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-main-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-score {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.item-sublevel {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 2rpx 12rpx;
  background: rgba(27,63,145,0.05);
  border-radius: var(--radius-sm);
}

.item-incomplete-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-muted);
}

.item-meta-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}

.item-meta {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.item-meta-dot {
  font-size: 22rpx;
  color: var(--text-placeholder);
  opacity: 0.5;
}

/* 右侧箭头 */
.item-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.chevron-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.25;
}

/* ========== 加载更多 ========== */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
}

.spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(27,63,145,0.15);
  border-top-color: var(--brand-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-more-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.no-more {
  text-align: center;
  padding: 32rpx;
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-placeholder);
}
