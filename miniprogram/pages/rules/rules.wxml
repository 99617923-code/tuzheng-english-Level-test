<!--
  途正英语AI分级测评 - 测评说明页
  小程序原生适配：全局导航布局 + wx.authorize录音授权
-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navBarHeight}}px;">
    <view class="custom-nav-content" style="margin-top: {{navContentTop}}px; height: {{navContentHeight}}px;">
      <view class="nav-back-btn" bindtap="goBack">
        <image class="nav-back-icon" src="/assets/icons/chevron-left.svg" mode="aspectFit" />
      </view>
      <text class="nav-title-center">测评说明</text>
      <view class="nav-right-placeholder"></view>
    </view>
  </view>

  <!-- 主体内容 -->
  <scroll-view scroll-y class="body" style="padding-top: {{navBarHeight}}px;">
    <!-- AI外教卡片 -->
    <view class="teacher-card glass-card-strong animate-fade-in">
      <image class="teacher-avatar" src="{{aiAvatarUrl}}" mode="aspectFill" />
      <view class="teacher-info">
        <text class="teacher-name">AI 外教</text>
        <text class="teacher-desc">我将和你进行一段英语对话，通过自适应算法精准评估你的英语水平</text>
      </view>
    </view>

    <!-- 测评原理简介 -->
    <view class="intro-card glass-card animate-fade-in-delay-1">
      <text class="intro-title">测评原理</text>
      <text class="intro-text">系统从基础题目开始，每答对一题自动升级到更高难度。题目会越来越难，直到找到你的真实水平为止。答题越多、通过的级别越高，最终等级就越高。</text>
    </view>

    <!-- 测评流程 - 带循环标记 -->
    <view class="section animate-fade-in-delay-1">
      <text class="section-title">测评流程</text>
      <view class="flow-steps">
        <view class="flow-step" wx:for="{{steps}}" wx:key="index">
          <!-- 左侧时间线 -->
          <view class="flow-timeline">
            <view class="flow-dot" style="background: {{item.color}};"></view>
            <view class="flow-line" wx:if="{{index < steps.length - 1}}" style="{{item.isLoop ? 'border-left-style: dashed; border-left-color: #e67e22;' : ''}}"></view>
          </view>
          <!-- 右侧内容 -->
          <view class="flow-content">
            <view class="flow-header">
              <view class="flow-icon-wrap" style="background: {{item.bgColor}};">
                <image class="flow-icon" src="/assets/icons/{{item.icon}}.svg" mode="aspectFit" />
              </view>
              <text class="flow-title" style="color: {{item.color}};">{{item.title}}</text>
              <view class="flow-loop-badge" wx:if="{{item.isLoop}}">
                <text class="flow-loop-text">循环</text>
              </view>
            </view>
            <text class="flow-desc">{{item.desc}}</text>
            <!-- 循环提示 -->
            <view class="loop-hint-card" wx:if="{{item.isLoop}}">
              <text class="loop-hint-text">🔄 步骤 ①~④ 会反复进行：听题 → 录音 → AI评估 → 过关升级 → 听更难的题……直到测出你的真实水平</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 注意事项 -->
    <view class="section animate-fade-in-delay-2">
      <text class="section-title">注意事项</text>
      <view class="tips-card glass-card">
        <view class="tip-item" wx:for="{{tips}}" wx:key="index">
          <view class="tip-dot" style="background: {{item.color}};"></view>
          <text class="tip-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 录音权限 -->
    <view class="permission-card {{recordPermission === 'authorized' ? 'permission-granted' : ''}} animate-fade-in-delay-3">
      <view class="permission-row">
        <view class="permission-icon-wrap {{recordPermission === 'authorized' ? 'icon-granted' : ''}}">
          <image class="permission-icon" src="/assets/icons/mic.svg" mode="aspectFit" />
        </view>
        <view class="permission-info">
          <text class="permission-title">录音权限</text>
          <text class="permission-desc">测评需要使用麦克风录制你的语音回答</text>
        </view>
      </view>
      <view class="permission-status">
        <text wx:if="{{recordPermission === 'authorized'}}" class="status-granted">✓ 已授权</text>
        <button wx:elif="{{recordPermission === 'denied'}}" class="permission-btn" bindtap="requestPermission">去设置开启</button>
        <button wx:else class="permission-btn" bindtap="requestPermission">点击授权</button>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-area">
      <button class="btn-primary {{recordPermission !== 'authorized' ? 'btn-disabled' : ''}}" bindtap="handleStartTest">
        <text>{{recordPermission === 'authorized' ? '开始测评' : '请先授权麦克风'}}</text>
      </button>
      <text class="bottom-hint">测评约需3-5分钟，从基础开始逐步升级</text>
    </view>
  </scroll-view>
</view>
