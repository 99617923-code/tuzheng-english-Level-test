/* 途正英语 - 欢迎页样式 */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-gradient);
}

/* 装饰圆形 */
.deco-circle { position: absolute; border-radius: 50%; }
.deco-1 { top: -160rpx; right: -100rpx; width: 416rpx; height: 416rpx; background: radial-gradient(circle, rgba(27,63,145,0.08) 0%, transparent 70%); }
.deco-2 { top: 35%; left: -80rpx; width: 256rpx; height: 256rpx; background: radial-gradient(circle, rgba(131,186,18,0.10) 0%, transparent 70%); }
.deco-3 { bottom: 15%; right: -60rpx; width: 320rpx; height: 320rpx; background: radial-gradient(circle, rgba(27,63,145,0.06) 0%, transparent 70%); }
.deco-4 { bottom: -100rpx; left: 15%; width: 288rpx; height: 288rpx; background: radial-gradient(circle, rgba(131,186,18,0.08) 0%, transparent 70%); }

.content {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 48rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo-wrap {
  display: flex;
  align-items: center;
}

.logo-img {
  height: 56rpx;
}

.auth-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255,255,255,0.6) !important;
  border-radius: var(--radius-full);
  padding: 12rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  line-height: 1;
}

.auth-btn-text {
  color: var(--text-tertiary);
}

.login-text {
  color: var(--brand-blue) !important;
  font-weight: 600;
}

/* Hero */
.hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: -32rpx;
}

.welcome {
  text-align: center;
  margin-bottom: 48rpx;
}

.greeting {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-green);
  margin-bottom: 16rpx;
}

.title-wrap {
  margin-bottom: 24rpx;
}

.title-line1 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
}

.title-line2 {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: var(--brand-blue);
  line-height: 1.3;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-muted);
  max-width: 560rpx;
  margin: 0 auto;
}

/* Video Card */
.video-card {
  width: 100%;
  max-width: 640rpx;
  background: rgba(255,255,255,0.60);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(27,63,145,0.08);
  border: 2rpx solid rgba(255,255,255,0.5);
  margin-bottom: 48rpx;
}

.video-card:active {
  transform: scale(0.98);
}

.video-area {
  position: relative;
  height: 352rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(27,63,145,0.06), rgba(131,186,18,0.06));
}

.play-btn-wrap {
  position: relative;
}

.play-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 128rpx;
  height: 128rpx;
  margin-top: -64rpx;
  margin-left: -64rpx;
  border-radius: 50%;
  background: rgba(27,63,145,0.10);
  animation: pulseRing 2s ease-out infinite;
}

.play-btn {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1B3F91, #2B5BA0);
  box-shadow: 0 8rpx 24rpx rgba(27,63,145,0.30);
}

.play-icon {
  width: 56rpx;
  height: 56rpx;
  margin-left: 8rpx;
}

.wave-bars {
  position: absolute;
  bottom: 24rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 6rpx;
}

.wave-bar {
  width: 5rpx;
  border-radius: 5rpx;
  background: rgba(27,63,145,0.20);
}

.video-info {
  padding: 24rpx 32rpx;
  text-align: center;
}

.video-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand-blue);
}

.video-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* History Entry */
.history-entry {
  width: 100%;
  max-width: 640rpx;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.55);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(27,63,145,0.06);
}

.history-entry:active {
  background: rgba(255,255,255,0.70);
}

.history-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.history-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(131,186,18,0.12);
}

.history-icon {
  width: 36rpx;
  height: 36rpx;
}

.history-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.history-arrow {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

/* CTA */
.cta-wrap {
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
}

.cta-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 24rpx;
}

/* Video Modal */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(8rpx);
}

.video-modal-content {
  width: 90%;
  max-width: 640rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 40rpx 120rpx rgba(0,0,0,0.30);
}

.video-player-wrap {
  width: 100%;
}

.video-player {
  width: 100%;
  height: 400rpx;
}

.video-placeholder {
  width: 100%;
  height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8eef8, #eef6e8);
}

.placeholder-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(27,63,145,0.10), rgba(131,186,18,0.10));
  margin-bottom: 32rpx;
}

.placeholder-icon {
  width: 56rpx;
  height: 56rpx;
  margin-left: 8rpx;
}

.placeholder-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-blue);
}

.placeholder-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.video-modal-footer {
  padding: 32rpx;
  text-align: center;
}

.close-btn {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-blue);
  background: rgba(27,63,145,0.06) !important;
  border-radius: var(--radius-full);
  padding: 16rpx 48rpx;
  line-height: 1.4;
}
